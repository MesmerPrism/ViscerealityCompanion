<Window x:Class="ViscerealityCompanion.App.StudyShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ViscerealityCompanion.App"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Study Shell"
        Icon="Assets/viscereality-companion.ico"
        Width="1480"
        Height="980"
        MinWidth="1240"
        MinHeight="860"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource InkBrush}">
    <Grid Margin="20"
          Background="{StaticResource AppBackgroundBrush}">
        <local:StudyShellView />
    </Grid>
</Window>
