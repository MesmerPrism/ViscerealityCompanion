                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                        <ProgressBar Margin="0,8,0,0"
                                     Height="8"
                                     Maximum="100"
                                     Value="{Binding TwinInspectorMatchPercent, Mode=OneWay}"
                                     Foreground="{Binding LiveSignalLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                        <TextBlock Text="{Binding TwinInspectorMatchLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="{Binding LastTwinStateTimestampLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="5" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="{Binding PrimaryWorkflowTabLabel}">
                <Grid>
                    <Grid Visibility="{Binding HasActiveStudyShell, Converter={StaticResource BoolToVisibility}}">
                        <local:StudyShellView
