                                        <TextBlock Text="Selected App" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SelectedAppSummary}" Style="{StaticResource SectionCaptionStyle}" />
                                        <TextBlock Text="{Binding SelectedAppCapabilitySummary}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,8,0,0" />
                                        <TextBlock Text="{Binding SelectedAppCommunicationSummary}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,8,0,0" />
                                        <TextBlock Text="{Binding SelectedAppPipelineLabel}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>

                                    <Border Grid.Column="2" Style="{StaticResource InsetPanelStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Library context" Style="{StaticResource EyebrowStyle}" />
                                            <TextBlock Text="{Binding CatalogStatus}"
                                                       FontWeight="Bold"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CatalogSourcePath}"
                                                       Style="{StaticResource InspectorKeyStyle}"
                                                       Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding SelectedHotloadProfileSummary}"
                                                       Style="{StaticResource MicroCaptionStyle}"
                                                       Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="0.95*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Install + Launch" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="Use per-app APK overrides or the staged Quest Session Kit catalog file."
                                                   Style="{StaticResource SectionCaptionStyle}" />
                                        <TextBlock Text="APK path" Style="{StaticResource EyebrowStyle}" />
                                        <TextBox Text="{Binding SelectedAppApkPath, UpdateSourceTrigger=PropertyChanged}" />
                                        <WrapPanel Margin="0,4,0,8">
                                            <Button Content="Browse APK" Command="{Binding BrowseApkCommand}" />
                                            <Button Content="Install Selected App" Command="{Binding InstallAppCommand}" />
                                            <Button Content="Install Bundle" Command="{Binding InstallBundleCommand}" />
                                            <Button Content="Launch App" Command="{Binding LaunchAppCommand}" />
                                        </WrapPanel>
                                        <Border Style="{StaticResource InsetPanelStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Bundle detail" Style="{StaticResource EyebrowStyle}" />
                                                <TextBlock Text="{Binding SelectedBundle.Label}" FontWeight="Bold" Margin="0,6,0,0" />
                                                <TextBlock Text="{Binding SelectedBundle.Description}"
                                                           Style="{StaticResource MicroCaptionStyle}"
                                                           Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Profiles + Performance" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="Keep hotload CSV staging, property presets, and direct CPU/GPU hints grouped together."
                                                   Style="{StaticResource SectionCaptionStyle}" />
                                        <TextBlock Text="Runtime preset" Style="{StaticResource EyebrowStyle}" />
                                        <ComboBox ItemsSource="{Binding AvailableHotloadProfiles}" SelectedItem="{Binding SelectedHotloadProfile}" />
                                        <WrapPanel Margin="0,4,0,8">
                                            <Button Content="Track Runtime Preset" Command="{Binding ApplyHotloadCommand}" />
                                            <Button Content="Track Over Twin" Command="{Binding ApplyTwinPresetCommand}" />
                                        </WrapPanel>
                                        <TextBlock Text="Device profile" Style="{StaticResource EyebrowStyle}" />
                                        <ComboBox ItemsSource="{Binding DeviceProfiles}" SelectedItem="{Binding SelectedDeviceProfile}" />
                                        <Button Content="Apply Device Profile" Command="{Binding ApplyDeviceProfileCommand}" />
                                        <TextBlock Text="Quest CPU / GPU" Style="{StaticResource EyebrowStyle}" Margin="0,14,0,0" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding CpuLevelText, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Column="2" Text="{Binding GpuLevelText, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                        <Button Content="Apply Performance Levels" Command="{Binding ApplyPerformanceLevelsCommand}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Runtime Config"
                     Visibility="{Binding ShowStandardOperatorSurface, Converter={StaticResource BoolToVisibility}}">
                <Grid Margin="4,16,4,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Runtime Config" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="The editor follows the Astral scene inspector: setup first, then tunable parameters, then coupling-adjacent timing and JSON bridge values."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <TextBlock Text="Profile" Style="{StaticResource EyebrowStyle}" />
                                <ComboBox ItemsSource="{Binding RuntimeConfig.Profiles}" SelectedItem="{Binding RuntimeConfig.SelectedProfile}" />
                                <Border Style="{StaticResource InsetPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Selected profile" Style="{StaticResource EyebrowStyle}" />
                                        <TextBlock Text="{Binding RuntimeConfig.SelectedProfileLabel}"
                                                   FontWeight="Bold"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding RuntimeConfig.SelectedProfileSummary}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource InsetPanelStyle}" Margin="0,14,0,0"
                                        Background="{Binding SussexParticleTuningLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                        BorderBrush="{Binding SussexParticleTuningLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="Sussex particle size tuning (V1)" Style="{StaticResource EyebrowStyle}" />
                                        <TextBlock Text="{Binding SussexParticleTuningSummary}"
                                                   FontWeight="Bold"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{Binding SussexParticleTuningLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                        <TextBlock Text="{Binding SussexParticleTuningDetail}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap" />
                                        <WrapPanel Margin="0,10,0,6">
                                            <Button Content="Import Tuning JSON" Command="{Binding ImportSussexParticleTuningCommand}" />
                                            <Button Content="Compile + Upload To Sussex" Command="{Binding ApplySussexParticleTuningCommand}" />
                                        </WrapPanel>
                                        <TextBlock Text="{Binding SussexParticleTuningValuesLabel}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SussexParticleTuningBaselineSummary}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SussexParticleTuningSourcePath}"
                                                   Style="{StaticResource InspectorKeyStyle}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SussexParticleTuningCompiledPath}"
                                                   Style="{StaticResource InspectorKeyStyle}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SussexParticleTuningTemplatePath}"
                                                   Style="{StaticResource InspectorKeyStyle}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <CheckBox Content="Remote-only research control"
                                          Margin="0,14,0,0"
                                          IsChecked="{Binding RemoteOnlyControlEnabled}" />
                                <WrapPanel Margin="0,12,0,6">
                                    <Button Content="Restore Profile" Command="{Binding ResetRuntimeConfigCommand}" />
                                    <Button Content="Export CSV" Command="{Binding ExportRuntimeConfigCommand}" />
                                    <Button Content="Publish Over Twin" Command="{Binding PublishRuntimeConfigCommand}" />
                                </WrapPanel>
                                <TextBlock Text="{Binding RuntimeConfigPublishSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="{Binding RuntimeConfigPublishChannelSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="{Binding RuntimeConfigLiveSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,8,0,0" />
                                <Border Style="{StaticResource InsetPanelStyle}" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Catalog source" Style="{StaticResource EyebrowStyle}" />
                                        <TextBlock Text="{Binding RuntimeConfig.CatalogStatus}"
                                                   FontWeight="Bold"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding RuntimeConfig.CatalogSourcePath}"
                                                   Style="{StaticResource InspectorKeyStyle}"
                                                   Margin="0,8,0,0" />
                                        <TextBlock Text="{Binding RuntimeConfig.LastExportPath}"
                                                   Style="{StaticResource InspectorKeyStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Inspector View" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="The editor follows the Viscereality scene more closely now: session inputs first, then headset policy, APK runtime policy, and finally twin/timing controls."
                                               Style="{StaticResource SectionCaptionStyle}" />
                                </StackPanel>
                            </Border>

                        <TabControl Grid.Row="2">
                            <TabItem Header="Session + Inputs">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding RuntimeConfig.SessionRoutingSections}" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Headset">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding RuntimeConfig.HeadsetSections}" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="APK Runtime">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding RuntimeConfig.ApkRuntimeSections}" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Twin + Timing">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding RuntimeConfig.TwinTimingSections}" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="All">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding RuntimeConfig.AllSections}" />
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Twin Monitor"
                     Visibility="{Binding ShowStandardOperatorSurface, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="4,16,4,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource PanelBorderStyle}"
                                Background="{Binding TwinBridgeLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                BorderBrush="{Binding TwinBridgeLevel, Converter={StaticResource OutcomeKindToBrush}}">
                            <StackPanel>
                                <TextBlock Text="Bridge" Style="{StaticResource EyebrowStyle}" />
                                <TextBlock Text="{Binding TwinBridgeSummary}"
                                           Style="{StaticResource MetricValueStyle}"
                                           FontSize="20"
                                           Foreground="{Binding TwinBridgeLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                <TextBlock Text="{Binding TwinBridgeDetail}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource PanelBorderStyle}"
                                Background="{Binding TwinPublisherLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                BorderBrush="{Binding TwinPublisherLevel, Converter={StaticResource OutcomeKindToBrush}}">
                            <StackPanel>
                                <TextBlock Text="Live publisher" Style="{StaticResource EyebrowStyle}" />
                                <TextBlock Text="{Binding LiveTwinPublisherLabel}"
                                           Style="{StaticResource MetricValueStyle}"
                                           FontSize="20"
                                           Foreground="{Binding TwinPublisherLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                <TextBlock Text="{Binding LiveTwinPublisherDetail}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4"
                                Style="{StaticResource PanelBorderStyle}"
                                Background="{Binding TwinAppStateLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                BorderBrush="{Binding TwinAppStateLevel, Converter={StaticResource OutcomeKindToBrush}}">
                            <StackPanel>
                                <TextBlock Text="Twin state" Style="{StaticResource EyebrowStyle}" />
                                <TextBlock Text="{Binding TwinAppStateSummary}"
                                           Style="{StaticResource MetricValueStyle}"
                                           FontSize="20"
                                           Foreground="{Binding TwinAppStateLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                <TextBlock Text="{Binding LastTwinStateTimestampLabel}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="0.85*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Twin Commands + Context" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Keep the first shipping mode simple: Windows issues commands and publishes requested settings, while the headset only reports state."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="Start" Command="{Binding SendTwinCommandCommand}" CommandParameter="twin-start" />
                                    <Button Content="Pause" Command="{Binding SendTwinCommandCommand}" CommandParameter="twin-pause" />
                                    <Button Content="Resume" Command="{Binding SendTwinCommandCommand}" CommandParameter="twin-resume" />
                                    <Button Content="Marker" Command="{Binding SendTwinCommandCommand}" CommandParameter="twin-marker" />
                                    <Button Content="Reset" Command="{Binding SendTwinCommandCommand}" CommandParameter="twin-reset" />
                                </WrapPanel>
                                <TextBlock Text="{Binding RemoteControlSelectionSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,12,0,0" />
                                <TextBlock Text="{Binding RemoteControlLiveContextSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Focused Inspector" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Pick one scene-aligned section at a time so the twin page stays readable even when the APK reports a large state snapshot."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <TextBlock Text="Focus area" Style="{StaticResource DetailLabelStyle}" Margin="0,10,0,0" />
                                <ComboBox ItemsSource="{Binding TwinInspectorScopes}"
                                          SelectedItem="{Binding SelectedTwinInspectorScope}"
                                          DisplayMemberPath="Label" />
                                <Border Style="{StaticResource InsetPanelStyle}" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TwinInspectorScopeSummary}"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap" />
                                        <ProgressBar Margin="0,10,0,0"
                                                     Height="10"
                                                     Maximum="100"
                                                     Value="{Binding TwinInspectorMatchPercent, Mode=OneWay}"
                                                     Foreground="{Binding TwinBridgeLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                        <TextBlock Text="{Binding TwinInspectorMatchLabel}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding TwinTrackingCoverageSummary}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding TwinAppStateDetail}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="0.9*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Tracked Values" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="The list is filtered to the selected focus area. That keeps the twin page useful without forcing all reported values into one constantly updating table."
                                               Style="{StaticResource SectionCaptionStyle}" />
                                </StackPanel>

                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding TwinInspectorRows}"
                                         SelectedItem="{Binding SelectedTwinInspectorRow}"
                                         MinHeight="320"
                                         MaxHeight="560"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="12"
                                                    CornerRadius="8"
                                                    Background="{Binding StatusLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                                    BorderBrush="{Binding StatusLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="14" />
                                                        <ColumnDefinition Width="220" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontWeight="Bold"
                                                                   FontSize="13"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding ScopeLabel}"
                                                                   Style="{StaticResource MicroCaptionStyle}"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                   Style="{StaticResource MicroCaptionStyle}"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Requested" Style="{StaticResource EyebrowStyle}" />
                                                        <TextBlock Text="{Binding Requested}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="Reported"
                                                                   Style="{StaticResource EyebrowStyle}"
                                                                   Margin="0,8,0,0" />
                                                        <TextBlock Text="{Binding Reported}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Selected Value" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding TwinInspectorSelectionHeadline}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TwinInspectorSelectionSource}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding TwinInspectorSelectionDetail}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,8,0,0" />

                                    <Border Style="{StaticResource InsetPanelStyle}" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Requested" Style="{StaticResource EyebrowStyle}" />
                                            <TextBlock Text="{Binding TwinInspectorSelectionRequested}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="Reported" Style="{StaticResource EyebrowStyle}" Margin="0,12,0,0" />
                                            <TextBlock Text="{Binding TwinInspectorSelectionReported}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Button Content="Publish Runtime Config" Command="{Binding PublishRuntimeConfigCommand}" />
                                        <Button Content="Refresh Device Snapshot" Command="{Binding RefreshHeadsetStatusCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                    <TextBlock Text="Twin Events" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Recent bridge frames remain visible here, but the list is intentionally shorter so the page stays stable while the state stream is active."
                                               Style="{StaticResource SectionCaptionStyle}" />
                                    </StackPanel>

                                    <ListBox Grid.Row="2"
                                             ItemsSource="{Binding TwinLiveEvents}"
                                             MinHeight="220"
                                             MaxHeight="420"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="12"
                                                        CornerRadius="8"
                                                        Background="{StaticResource PanelAltBrush}"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                                   Style="{StaticResource EyebrowStyle}" />
                                                        <TextBlock Text="{Binding Category}"
                                                                   FontWeight="Bold"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding Payload}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="12"
                                                                   Margin="0,6,0,0"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Detail}"
                                                                   Style="{StaticResource MicroCaptionStyle}"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                    </Grid>
                    </ScrollViewer>
            </TabItem>

            <TabItem Header="LSL Monitor"
                     Visibility="{Binding ShowStandardOperatorSurface, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="4,16,4,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Live Monitor" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="This remains the simple read-only telemetry surface, aligned with Astral's quest_monitor outlet defaults."
                                       Style="{StaticResource SectionCaptionStyle}" />
                            <TextBlock Text="{Binding MonitorValueLabel}"
                                       FontSize="54"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource FocusBlueBrush}" />
                            <TextBlock Text="{Binding MonitorRateLabel}" Style="{StaticResource EyebrowStyle}" />
                            <ProgressBar Margin="0,16,0,0" Height="12" Maximum="1" Value="{Binding MonitorValue, Mode=OneWay}" />
                            <TextBlock Text="{Binding MonitorSummary}"
                                       FontWeight="Bold"
                                       Margin="0,16,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding MonitorDetail}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Monitor Contract" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Defaults match Quest Session Kit and the Astral scene: quest_monitor / quest.telemetry, channel 0."
                                           Style="{StaticResource SectionCaptionStyle}" />
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.95*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="1.05*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource InsetPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Subscription" Style="{StaticResource EyebrowStyle}" />
                                        <TextBlock Text="Stream name" Style="{StaticResource EyebrowStyle}" Margin="0,10,0,0" />
                                        <TextBox Text="{Binding MonitorStreamName, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Stream type" Style="{StaticResource EyebrowStyle}" />
                                        <TextBox Text="{Binding MonitorStreamType, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Channel index" Style="{StaticResource EyebrowStyle}" />
                                        <TextBox Text="{Binding MonitorChannelIndexText, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Content="Restart Monitor" Command="{Binding RestartMonitorCommand}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource InsetPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Notes" Style="{StaticResource EyebrowStyle}" />
                                        <TextBlock Text="Use this page for quick LSL transport checks. Richer app-state comparisons remain in Twin Monitor."
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding RemoteControlLiveContextSummary}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,10,0,0" />
                                        <TextBlock Text="{Binding MonitorDetail}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                    </Grid>
                    </ScrollViewer>
            </TabItem>

            <TabItem Header="Diagnostics"
                     Visibility="{Binding ShowStandardOperatorSurface, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="4,16,4,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Utilities" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Operator shortcuts stay separate from the core flow, but they still use the same ADB session and snapshot refresh logic."
                                       Style="{StaticResource SectionCaptionStyle}" />
                            <ItemsControl ItemsSource="{Binding UtilityActions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InsetPanelStyle}" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="14" />
                                                <TextBlock Text="{Binding Description}"
                                                           Style="{StaticResource MicroCaptionStyle}"
                                                           Margin="0,6,0,10" />
                                                <Button Content="{Binding Label}"
                                                        Command="{Binding DataContext.RunUtilityCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                        CommandParameter="{Binding Value}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Style="{StaticResource InsetPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Current sources" Style="{StaticResource EyebrowStyle}" />
                                    <TextBlock Text="{Binding CatalogSourcePath}"
                                               Style="{StaticResource InspectorKeyStyle}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding LatestManifestPath}"
                                               Style="{StaticResource InspectorKeyStyle}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Operator Log" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="The working core remains visible here while the UI is being tightened around it."
                                       Style="{StaticResource SectionCaptionStyle}" />
                            <DataGrid Margin="0,10,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      MinHeight="360"
                                      MaxHeight="680"
                                      ItemsSource="{Binding Logs}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="90" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="100" />
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="1.2*" />
                                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
