                            Background="{Binding HeaderLiveLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding HeaderLiveLevel, Converter={StaticResource OutcomeKindToBrush}}">
                        <StackPanel>
                            <TextBlock Text="Live runtime signal" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="{Binding LiveSignalHeadline}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding LiveSignalDetail}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      Visibility="{Binding ShowExpandedStudyBanner, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="252"
                            Margin="0,0,8,8"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10"
                            Background="{Binding ActiveStudyShell.PinnedBuildLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding ActiveStudyShell.PinnedBuildLevel, Converter={StaticResource OutcomeKindToBrush}}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Verified runtime" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="{Binding ActiveStudyShell.PinnedBuildSummary}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{Binding ActiveStudyShell.PinnedBuildLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ActiveStudyShell.PinnedPackageId}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Details" Style="{StaticResource EyebrowStyle}" />
                                </Expander.Header>
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Text="{Binding ActiveStudyShell.PinnedBuildDetail}"
                                               Style="{StaticResource MicroCaptionStyle}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.InstalledApkDetail}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="0"
                            Margin="0"
                            Style="{StaticResource StatusBandPanelStyle}"
