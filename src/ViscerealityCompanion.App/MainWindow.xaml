<Window x:Class="ViscerealityCompanion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ViscerealityCompanion.App"
        xmlns:models="clr-namespace:ViscerealityCompanion.Core.Models;assembly=ViscerealityCompanion.Core"
        xmlns:viewModels="clr-namespace:ViscerealityCompanion.App.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1520"
        Height="980"
        MinWidth="1280"
        MinHeight="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource InkBrush}">
    <Window.Resources>
        <local:CountToVisibilityConverter x:Key="CountToVisibility" />
        <local:SyncStateToBrushConverter x:Key="SyncStateToBrush" />
        <local:SyncStateToTooltipConverter x:Key="SyncStateToTooltip" />
        <local:OutcomeKindToBrushConverter x:Key="OutcomeKindToBrush" />
        <local:OutcomeKindToSoftBrushConverter x:Key="OutcomeKindToSoftBrush" />
        <local:BoolToBrushConverter x:Key="BoolToBrush" />
        <local:BoolToSoftBrushConverter x:Key="BoolToSoftBrush" />
        <local:BoolToStatusTextConverter x:Key="BoolToStatusText" />
        <local:StatusDetailFormatterConverter x:Key="StatusDetailFormatter" />
        <local:LogLevelToBrushConverter x:Key="LogLevelToBrush" />
        <local:BatteryToBrushConverter x:Key="BatteryToBrush" />
        <local:TagsToBadgeTextConverter x:Key="TagsToBadgeText" />
        <local:TagsToBrushConverter x:Key="TagsToBrush" />
        <local:TagsToSoftBrushConverter x:Key="TagsToSoftBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <Style x:Key="InsetPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="RailListStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="EyebrowStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MicroCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="StatusBandPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="CompactStatusExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource FocusBlueBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Padding" Value="14,9" />
        </Style>

        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="StepIndexStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource FocusBlueBrush}" />
        </Style>

        <Style x:Key="InspectorKeyStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <DataTemplate DataType="{x:Type models:QuestAppTarget}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Label}"
                               FontWeight="Bold"
                               FontSize="14"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding PackageId}"
                               Style="{StaticResource InspectorKeyStyle}"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding Description}"
                               Style="{StaticResource MicroCaptionStyle}"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource ChipBorderStyle}"
                        Margin="12,0,0,0"
                        VerticalAlignment="Top"
                        Background="{Binding Tags, Converter={StaticResource TagsToSoftBrush}}"
                        BorderBrush="{Binding Tags, Converter={StaticResource TagsToBrush}}">
                    <TextBlock Text="{Binding Tags, Converter={StaticResource TagsToBadgeText}}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{Binding Tags, Converter={StaticResource TagsToBrush}}" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:StudyShellDefinition}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Label}"
                               FontWeight="Bold"
                               FontSize="14"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Partner}"
                               Style="{StaticResource MicroCaptionStyle}"
                               Margin="0,4,0,0" />
                    <TextBlock Text="{Binding Description}"
                               Style="{StaticResource MicroCaptionStyle}"
                               Margin="0,6,0,0"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Open Study Mode"
                        Command="{Binding DataContext.OpenStudyShellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="12,0,0,0"
                        VerticalAlignment="Top" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:SingleValueRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <TextBox Grid.Column="2"
                             Margin="12"
                             Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ToggleRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <CheckBox Grid.Column="2"
                              Margin="12"
                              VerticalAlignment="Center"
                              Content="Enabled"
                              IsChecked="{Binding Value}" />
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ChoiceRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <ComboBox Grid.Column="2"
                              Margin="12"
                              ItemsSource="{Binding Options}"
                              SelectedItem="{Binding SelectedOption}" />
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RangeRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Grid Grid.Column="2" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding MaximumText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:Vector3RowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Grid Grid.Column="2" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding XText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Column="2" Text="{Binding YText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Column="4" Text="{Binding ZText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MultilineRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding Description}" Style="{StaticResource MicroCaptionStyle}" Margin="0,12,0,0" />
                    </StackPanel>
                    <TextBox Grid.Column="2"
                             Margin="12"
                             MinHeight="110"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RuntimeConfigSectionViewModel}">
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold" />
                    <TextBlock Text="{Binding Description}"
                               Style="{StaticResource SectionCaptionStyle}"
                               Margin="0,6,0,12" />
                    <ItemsControl ItemsSource="{Binding Rows}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20"
          Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource AccentBrush}"
                CornerRadius="3" />

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Visibility="{Binding HasActiveStudyShell, Converter={StaticResource InverseBoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource SurfaceTintBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8"
                            VerticalAlignment="Center">
                        <Image Source="Assets/viscereality-wordmark.png"
                               Height="82"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="Windows operator companion"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="Install the supplied Quest build, monitor live study state, and keep operator control on Windows."
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0"
                                   MaxWidth="560" />
                    </StackPanel>

                    <Border Grid.Column="4"
                            Style="{StaticResource InsetPanelStyle}"
                            Padding="12,10"
                            VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceTintBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10">
                            <StackPanel>
                                <TextBlock Text="Current mode"
                                           Style="{StaticResource EyebrowStyle}" />
                                <TextBlock Text="{Binding CurrentModeLabel}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding HeaderModeSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                                <Border Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Opened Build"
                                                   Style="{StaticResource EyebrowStyle}" />
                                        <TextBlock Text="{Binding PublishedBuildSummary}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding PublishedBuildDetail}"
                                                   Style="{StaticResource MicroCaptionStyle}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding LslRuntimeSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,8,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FocusBlueBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LslRuntimeDetail}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,4,0,0"
                                           FontFamily="{StaticResource MonoFont}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Border>

                    <WrapPanel Grid.Column="6"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               ItemHeight="38">
                        <Button Content="{Binding StudyModeHeaderButtonLabel}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding OpenStudyShellCommand}"
                                CommandParameter="{Binding FeaturedStudyShell}"
                                Visibility="{Binding ShowStudyModeAction, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="Exit Study Mode"
                                Command="{Binding ExitStudyModeCommand}"
                                Visibility="{Binding CanExitStudyMode, Converter={StaticResource BoolToVisibility}}" />
                        <CheckBox Content="Remote-only research control"
                                  Margin="0,6,10,0"
                                  IsChecked="{Binding RemoteOnlyControlEnabled}"
                                  Visibility="{Binding ShowOperatorHeaderUtilities, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="Refresh Snapshot"
                                Command="{Binding RefreshHeadsetStatusCommand}"
                                Visibility="{Binding ShowOperatorHeaderUtilities, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="Refresh Active App"
                                Command="{Binding RefreshForegroundCommand}"
                                Visibility="{Binding ShowOperatorHeaderUtilities, Converter={StaticResource BoolToVisibility}}" />
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="0"
                      Visibility="{Binding HasActiveStudyShell, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource InsetPanelStyle}"
                            Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource SurfaceTintBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="4">
                                <Image Source="Assets/viscereality-companion.png"
                                       Width="50"
                                       Height="50"
                                       Stretch="Uniform" />
                            </Border>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActiveStudyShell.StudyLabel}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding CurrentModeLabel}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           FontWeight="SemiBold"
                                           Margin="0,2,0,0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ActiveStudyShell.PinnedBuildSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,4,0,0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ActiveStudyShell.DeviceProfileSummary}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,2,0,0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10,8"
                            Background="{Binding ActiveStudyShell.QuestStatusLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding ActiveStudyShell.QuestStatusLevel, Converter={StaticResource OutcomeKindToBrush}}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Headset" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="{Binding ActiveStudyShell.QuestStatusSummary}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{Binding ActiveStudyShell.QuestStatusLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ActiveStudyShell.HeadsetBatteryLabel}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,4,0,0"
                                       Foreground="{Binding ActiveStudyShell.BatteryPercent, Converter={StaticResource BatteryToBrush}}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10,8"
                            Background="{Binding ActiveStudyShell.LiveRuntimeLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding ActiveStudyShell.LiveRuntimeLevel, Converter={StaticResource OutcomeKindToBrush}}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Live runtime" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="{Binding ActiveStudyShell.LiveRuntimeSummary}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{Binding ActiveStudyShell.LiveRuntimeLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ActiveStudyShell.LastTwinStateTimestampLabel}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10,8"
