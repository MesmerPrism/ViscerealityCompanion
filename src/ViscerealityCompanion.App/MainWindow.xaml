                                       Margin="0,4,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource StatusBandPanelStyle}"
