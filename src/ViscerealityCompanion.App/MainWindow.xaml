<Window x:Class="ViscerealityCompanion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ViscerealityCompanion.App"
        xmlns:models="clr-namespace:ViscerealityCompanion.Core.Models;assembly=ViscerealityCompanion.Core"
        xmlns:viewModels="clr-namespace:ViscerealityCompanion.App.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Viscereality Companion"
        Icon="Assets/viscereality-companion.ico"
        Width="1520"
        Height="980"
        MinWidth="1280"
        MinHeight="860"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:CountToVisibilityConverter x:Key="CountToVisibility" />
        <local:SyncStateToBrushConverter x:Key="SyncStateToBrush" />
        <local:SyncStateToTooltipConverter x:Key="SyncStateToTooltip" />
        <local:OutcomeKindToBrushConverter x:Key="OutcomeKindToBrush" />
        <local:OutcomeKindToSoftBrushConverter x:Key="OutcomeKindToSoftBrush" />
        <local:BoolToBrushConverter x:Key="BoolToBrush" />
        <local:BoolToSoftBrushConverter x:Key="BoolToSoftBrush" />
        <local:BoolToStatusTextConverter x:Key="BoolToStatusText" />
        <local:LogLevelToBrushConverter x:Key="LogLevelToBrush" />
        <local:BatteryToBrushConverter x:Key="BatteryToBrush" />
        <local:TagsToBadgeTextConverter x:Key="TagsToBadgeText" />
        <local:TagsToBrushConverter x:Key="TagsToBrush" />
        <local:TagsToSoftBrushConverter x:Key="TagsToSoftBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="InsetPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="RailListStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="EyebrowStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MicroCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="StatusBandPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="StepIndexStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource FocusBlueBrush}" />
        </Style>

        <Style x:Key="InspectorKeyStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <DataTemplate DataType="{x:Type models:QuestAppTarget}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Label}"
                               FontWeight="Bold"
                               FontSize="14"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding PackageId}"
                               Style="{StaticResource InspectorKeyStyle}"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding Description}"
                               Style="{StaticResource MicroCaptionStyle}"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource ChipBorderStyle}"
                        Margin="12,0,0,0"
                        VerticalAlignment="Top"
                        Background="{Binding Tags, Converter={StaticResource TagsToSoftBrush}}"
                        BorderBrush="{Binding Tags, Converter={StaticResource TagsToBrush}}">
                    <TextBlock Text="{Binding Tags, Converter={StaticResource TagsToBadgeText}}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{Binding Tags, Converter={StaticResource TagsToBrush}}" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:SingleValueRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <TextBox Grid.Column="2"
                             Margin="12"
                             Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ToggleRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <CheckBox Grid.Column="2"
                              Margin="12"
                              VerticalAlignment="Center"
                              Content="Enabled"
                              IsChecked="{Binding Value}" />
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ChoiceRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <ComboBox Grid.Column="2"
                              Margin="12"
                              ItemsSource="{Binding Options}"
                              SelectedItem="{Binding SelectedOption}" />
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RangeRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Grid Grid.Column="2" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding MaximumText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:Vector3RowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Grid Grid.Column="2" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding XText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Column="2" Text="{Binding YText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Column="4" Text="{Binding ZText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <TextBlock Grid.Column="3"
                               Margin="12"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="{Binding Description}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MultilineRowViewModel}">
            <Border Margin="0,0,0,8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="225" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                            CornerRadius="7,0,0,7"
                            ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <StackPanel Grid.Column="1" Margin="12">
                        <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Key}" Style="{StaticResource InspectorKeyStyle}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding Description}" Style="{StaticResource MicroCaptionStyle}" Margin="0,12,0,0" />
                    </StackPanel>
                    <TextBox Grid.Column="2"
                             Margin="12"
                             MinHeight="110"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RuntimeConfigSectionViewModel}">
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold" />
                    <TextBlock Text="{Binding Description}"
                               Style="{StaticResource SectionCaptionStyle}"
                               Margin="0,6,0,12" />
                    <ItemsControl ItemsSource="{Binding Rows}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource AccentBrush}"
                CornerRadius="3" />

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="430" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Viscereality Companion"
                               FontSize="31"
                               FontWeight="Bold" />
                    <TextBlock Text="Install the supplied Quest build, monitor live state, and stage runtime settings from Windows."
                               Style="{StaticResource SectionCaptionStyle}"
                               Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding TargetSelectionHeadline}"
                               FontSize="16"
                               FontWeight="Bold"
                               TextAlignment="Right"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding TargetSelectionDetail}"
                               Style="{StaticResource MicroCaptionStyle}"
                               Margin="0,6,0,0"
                               TextAlignment="Right" />
                    <WrapPanel Margin="0,12,0,0" HorizontalAlignment="Right">
                        <CheckBox Content="Remote-only research control"
                                  Margin="0,6,12,0"
                                  IsChecked="{Binding RemoteOnlyControlEnabled}" />
                        <Button Content="Refresh Device Snapshot" Command="{Binding RefreshHeadsetStatusCommand}" />
                        <Button Content="Refresh Foreground" Command="{Binding RefreshForegroundCommand}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="14,10"
                CornerRadius="8"
                Background="{StaticResource StatusWarningSoftBrush}"
                BorderBrush="{StaticResource StatusWarningBrush}"
                BorderThickness="1"
                Visibility="{Binding IsSelectedAppIncompatible, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding IncompatibleBannerLabel}"
                       FontWeight="Bold"
                       Foreground="{StaticResource StatusWarningBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource StatusBandPanelStyle}"
                        Background="{Binding IsQuestConnected, Converter={StaticResource BoolToSoftBrush}}"
                        BorderBrush="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}">
                    <StackPanel>
                        <TextBlock Text="Quest"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding ConnectionStatusLabel}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding HeadsetModel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding SessionHealthSummary}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource StatusBandPanelStyle}"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{Binding BatteryPercent, Converter={StaticResource BatteryToBrush}}">
                    <StackPanel>
                        <TextBlock Text="Battery / Performance"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding HeadsetBatteryLabel}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{Binding BatteryPercent, Converter={StaticResource BatteryToBrush}}" />
                        <ProgressBar Margin="0,8,0,0"
                                     Height="8"
                                     Maximum="100"
                                     Value="{Binding BatteryPercent, Mode=OneWay}"
                                     Foreground="{Binding BatteryPercent, Converter={StaticResource BatteryToBrush}}" />
                        <TextBlock Text="{Binding HeadsetPerformanceLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource StatusBandPanelStyle}"
                        Background="{Binding TargetStatusLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                        BorderBrush="{Binding TargetStatusLevel, Converter={StaticResource OutcomeKindToBrush}}">
                    <StackPanel>
                        <TextBlock Text="On Device"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding HeadsetTargetStatusLabel}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{Binding TargetStatusLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding HeadsetForegroundPackage}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding HeadsetActivityLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding DeviceSnapshotAgeLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6"
                        Style="{StaticResource StatusBandPanelStyle}"
                        Background="{Binding LiveSignalLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                        BorderBrush="{Binding LiveSignalLevel, Converter={StaticResource OutcomeKindToBrush}}">
                    <StackPanel>
                        <TextBlock Text="Live Signals"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding LiveSignalHeadline}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{Binding LiveSignalLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding TwinBridgeSummary}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                        <ProgressBar Margin="0,8,0,0"
                                     Height="8"
                                     Maximum="100"
                                     Value="{Binding TwinInspectorMatchPercent, Mode=OneWay}"
                                     Foreground="{Binding LiveSignalLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                        <TextBlock Text="{Binding TwinInspectorMatchLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="{Binding LastTwinStateTimestampLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="5">
            <TabItem Header="Start Here">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="4,16,4,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="0.75*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Start Here" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="This page is the first-session workflow for operators who receive a supplied APK and need one direct path: connect the headset, install the build, launch it, confirm telemetry, and keep the session under Windows control."
                                               Style="{StaticResource SectionCaptionStyle}" />

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource InsetPanelStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Before the first session"
                                                           FontSize="15"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="1. Put the Quest in developer mode and approve USB debugging once."
                                                           Style="{StaticResource MicroCaptionStyle}"
                                                           Margin="0,10,0,0" />
                                                <TextBlock Text="2. Keep Android platform-tools installed so the app can find adb."
                                                           Style="{StaticResource MicroCaptionStyle}"
                                                           Margin="0,8,0,0" />
                                                <TextBlock Text="3. Get the study APK, package id, and recommended preset from the research team."
                                                           Style="{StaticResource MicroCaptionStyle}"
                                                           Margin="0,8,0,0" />
                                                <TextBlock Text="4. Treat the headset as participant-facing: the operator app handles install, launch, monitoring, and tracked config changes."
                                                           Style="{StaticResource MicroCaptionStyle}"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Style="{StaticResource InsetPanelStyle}">
                                            <StackPanel>
                                                <TextBlock Text="What stays in operator control"
                                                           FontSize="15"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="The current shipping mode is remote-first. The APK reports state, while Windows handles study setup, device performance, runtime-config staging, and trigger commands."
                                                           Style="{StaticResource MicroCaptionStyle}"
                                                           Margin="0,10,0,0" />
                                                <TextBlock Text="Use the detailed tabs when you need full library browsing, the inspector-style config editor, raw twin-state comparisons, or diagnostics."
                                                           Style="{StaticResource MicroCaptionStyle}"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Current study setup" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding SelectedAppSummary}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedAppCapabilitySummary}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding CatalogStatus}"
                                               FontWeight="Bold"
                                               Margin="0,14,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding CatalogSourcePath}"
                                               Style="{StaticResource InspectorKeyStyle}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding SelectedHotloadProfileSummary}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="{Binding RuntimeConfigPublishSummary}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
