<Window x:Class="ViscerealityCompanion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ViscerealityCompanion.App"
        xmlns:viewModels="clr-namespace:ViscerealityCompanion.App.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Viscereality Companion // Operator Console"
        Width="1380"
        Height="940"
        MinWidth="1180"
        MinHeight="820"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:CountToVisibilityConverter x:Key="CountToVisibility" />
        <local:SyncStateToBrushConverter x:Key="SyncStateToBrush" />
        <local:SyncStateToTooltipConverter x:Key="SyncStateToTooltip" />
        <local:OutcomeKindToBrushConverter x:Key="OutcomeKindToBrush" />
        <local:OutcomeKindToSoftBrushConverter x:Key="OutcomeKindToSoftBrush" />
        <local:BoolToBrushConverter x:Key="BoolToBrush" />
        <local:BoolToSoftBrushConverter x:Key="BoolToSoftBrush" />
        <local:BoolToStatusTextConverter x:Key="BoolToStatusText" />
        <local:LogLevelToBrushConverter x:Key="LogLevelToBrush" />
        <local:BatteryToBrushConverter x:Key="BatteryToBrush" />
        <local:TagsToBadgeTextConverter x:Key="TagsToBadgeText" />
        <local:TagsToBrushConverter x:Key="TagsToBrush" />
        <local:TagsToSoftBrushConverter x:Key="TagsToSoftBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <DataTemplate DataType="{x:Type viewModels:SingleValueRowViewModel}">
            <Border Background="{StaticResource PanelBrush}" CornerRadius="5" Padding="8,6" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                             ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               TextWrapping="Wrap" />
                    <TextBox Grid.Column="2"
                             Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Description}"
                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ToggleRowViewModel}">
            <Border Background="{StaticResource PanelBrush}" CornerRadius="5" Padding="8,6" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                             ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               TextWrapping="Wrap" />
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding Value}"
                              VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Description}"
                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ChoiceRowViewModel}">
            <Border Background="{StaticResource PanelBrush}" CornerRadius="5" Padding="8,6" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                             ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               TextWrapping="Wrap" />
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding Options}"
                              SelectedItem="{Binding SelectedOption}"
                              Margin="0" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Description}"
                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RangeRowViewModel}">
            <Border Background="{StaticResource PanelBrush}" CornerRadius="5" Padding="8,6" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                             ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               TextWrapping="Wrap" />
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding MaximumText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0" />
                    </Grid>
                    <TextBlock Grid.Column="3"
                               Text="{Binding Description}"
                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:Vector3RowViewModel}">
            <Border Background="{StaticResource PanelBrush}" CornerRadius="5" Padding="8,6" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                             ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               TextWrapping="Wrap" />
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding XText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding YText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0" />
                        <TextBox Grid.Column="4"
                                 Text="{Binding ZText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0" />
                    </Grid>
                    <TextBlock Grid.Column="3"
                               Text="{Binding Description}"
                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MultilineRowViewModel}">
            <Border Background="{StaticResource PanelBrush}" CornerRadius="5" Padding="10,8" Margin="0,0,0,6">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0"
                                 Fill="{Binding SyncState, Converter={StaticResource SyncStateToBrush}}"
                                 ToolTip="{Binding SyncState, Converter={StaticResource SyncStateToTooltip}}" />
                        <TextBlock Text="{Binding Label}"
                                   FontWeight="SemiBold" FontSize="13" />
                    </StackPanel>
                    <TextBlock Text="{Binding Description}"
                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="80"
                             Margin="0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="58"
                                Height="58"
                                CornerRadius="16"
                                Margin="0,0,14,0"
                                Background="#FFF4E8D6"
                                BorderBrush="#FFE0B77D"
                                BorderThickness="1">
                            <Grid>
                                <Ellipse Width="34"
                                         Height="34"
                                         Fill="#FFF7C873"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                                <Ellipse Width="42"
                                         Height="42"
                                         Stroke="#FF2B6A73"
                                         StrokeThickness="3"
                                         StrokeDashCap="Round"
                                         StrokeStartLineCap="Round"
                                         StrokeEndLineCap="Round"
                                         StrokeDashArray="1.2 1.8"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                                <Path Data="M 16,36 C 24,17 36,16 44,37"
                                      Stroke="#FF8A4B2A"
                                      StrokeThickness="3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="#FF2B6A73"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="Viscereality Companion"
                                       FontSize="30"
                                       FontWeight="Bold" />
                            <TextBlock Text="Operator Console"
                                       Margin="0,2,0,0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FF8A4B2A" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Public Windows operator shell for AstralKarateDojo Quest Session Kit control, telemetry monitoring, and remote study orchestration."
                               Style="{StaticResource SectionCaptionStyle}"
                               Margin="0,8,0,0" />
                    <WrapPanel Margin="0,6,0,0">
                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                                HorizontalAlignment="Left"
                                Background="{Binding IsQuestConnected, Converter={StaticResource BoolToSoftBrush}}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0"
                                         Fill="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}" />
                                <TextBlock Text="{Binding IsQuestConnected, Converter={StaticResource BoolToStatusText}}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}" />
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="4" Padding="8,4"
                                HorizontalAlignment="Left"
                                Background="{Binding HeadsetActivityLevel, Converter={StaticResource OutcomeKindToSoftBrush}}">
                            <StackPanel>
                                <TextBlock Text="{Binding HeadsetActivityLabel}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{Binding HeadsetActivityLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                <TextBlock Text="{Binding HeadsetActivityDetail}"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Catalog"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CatalogStatus}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                    <TextBlock Text="{Binding CatalogSourcePath}"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="12"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Twin Monitor"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RemoteControlModeSummary}"
                               Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding TwinBridgeDetail}"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Global incompatible-app warning banner -->
        <Border Grid.Row="1" CornerRadius="6" Padding="14,10" Margin="0,8,0,0"
                Background="{StaticResource StatusWarningSoftBrush}"
                BorderBrush="{StaticResource StatusWarningBrush}"
                BorderThickness="1.5"
                Visibility="{Binding IsSelectedAppIncompatible, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{StaticResource StatusWarningBrush}" />
                <TextBlock Text="{Binding IncompatibleBannerLabel}" TextWrapping="Wrap"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource StatusWarningBrush}" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="3"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}">
            <TabItem Header="Session">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Quest Endpoint" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="USB bootstrap first, then hold onto the working Wi-Fi ADB endpoint."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <TextBlock Text="Endpoint" FontWeight="SemiBold" />
                                <TextBox Text="{Binding EndpointDraft, UpdateSourceTrigger=PropertyChanged}" />
                                <WrapPanel>
                                    <Button Content="Probe USB"
                                            Command="{Binding ProbeUsbCommand}" />
                                    <Button Content="Find Wi-Fi Quest"
                                        Command="{Binding DiscoverWifiCommand}" />
                                    <Button Content="Enable Wi-Fi ADB"
                                            Command="{Binding EnableWifiCommand}" />
                                    <Button Content="Connect Quest"
                                            Command="{Binding ConnectQuestCommand}"
                                            Background="{StaticResource AccentSoftBrush}" />
                                </WrapPanel>
                                <Separator Margin="0,10,0,10" />

                                <!-- Connection status with colored indicator -->
                                <TextBlock Text="Connection" FontWeight="SemiBold" />
                                <Border CornerRadius="4" Padding="8,6" Margin="0,4,0,8"
                                        Background="{Binding IsQuestConnected, Converter={StaticResource BoolToSoftBrush}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Fill="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}" />
                                        <TextBlock Text="{Binding ConnectionSummary}" TextWrapping="Wrap"
                                                   Foreground="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="USB summary" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding UsbSummary}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Headset Status" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Live ADB status tracks install state, foreground package, battery, and CPU/GPU levels while config changes stay operator-side."
                                           Style="{StaticResource SectionCaptionStyle}" />

                                <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                                        Background="{StaticResource PanelAltBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Selected target capability" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedAppCapabilitySummary}"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedAppCommunicationSummary}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <!-- Headset status summary chip -->
                                <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                                        Background="{Binding IsQuestConnected, Converter={StaticResource BoolToSoftBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding HeadsetStatusSummary}" FontWeight="SemiBold"
                                                   Foreground="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}" />
                                        <TextBlock Text="{Binding HeadsetStatusDetail}" Margin="0,2,0,0" TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding HeadsetModel}" Margin="0,0,0,6" FontWeight="SemiBold" />

                                <!-- Battery bar -->
                                <TextBlock Text="{Binding HeadsetBatteryLabel}" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ProgressBar Minimum="0" Maximum="100" Height="12"
                                             Value="{Binding BatteryPercent, Mode=OneWay}"
                                             Foreground="{Binding BatteryPercent, Converter={StaticResource BatteryToBrush}}"
                                             Margin="0,0,0,10" />

                                <TextBlock Text="{Binding HeadsetPerformanceLabel}" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding HeadsetForegroundPackage}" Margin="0,0,0,4"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" />

                                <!-- Foreground mismatch warning (Session tab) -->
                                <Border CornerRadius="4" Padding="8,4" Margin="0,0,0,4"
                                        Visibility="{Binding IsForegroundMismatch, Converter={StaticResource BoolToVisibility}}"
                                        Background="{StaticResource StatusWarningSoftBrush}">
                                    <TextBlock Text="{Binding ForegroundMismatchLabel}" TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{StaticResource StatusWarningBrush}" />
                                </Border>

                                <!-- Target status chip -->
                                <Border CornerRadius="4" Padding="8,4" Margin="0,4,0,12"
                                        Background="{Binding TargetStatusLevel, Converter={StaticResource OutcomeKindToSoftBrush}}">
                                    <TextBlock Text="{Binding HeadsetTargetStatusLabel}" TextWrapping="Wrap"
                                               Foreground="{Binding TargetStatusLevel, Converter={StaticResource OutcomeKindToBrush}}" FontWeight="SemiBold" />
                                </Border>

                                <!-- Settings Delta (twin bridge comparison) -->
                                <TextBlock Text="Settings Delta" FontWeight="SemiBold"
                                           Visibility="{Binding SettingsDelta.Count, Converter={StaticResource CountToVisibility}}" />
                                <DataGrid ItemsSource="{Binding SettingsDelta}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          MaxHeight="200"
                                          Margin="0,4,0,12"
                                          Visibility="{Binding SettingsDelta.Count, Converter={StaticResource CountToVisibility}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*" />
                                        <DataGridTextColumn Header="Requested" Binding="{Binding Requested}" Width="100" />
                                        <DataGridTextColumn Header="Reported" Binding="{Binding Reported}" Width="100" />
                                        <DataGridCheckBoxColumn Header="Match" Binding="{Binding Matches}" Width="50" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Manifest path" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LatestManifestPath}"
                                           Margin="0,4,0,12"
                                           FontFamily="{StaticResource MonoFont}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Browser URL" FontWeight="SemiBold" />
                                <TextBox Text="{Binding BrowserUrlDraft, UpdateSourceTrigger=PropertyChanged}" />
                                <WrapPanel>
                                    <Button Content="Refresh Catalogs"
                                            Command="{Binding RefreshCatalogCommand}" />
                                    <Button Content="Refresh Headset Status"
                                            Command="{Binding RefreshHeadsetStatusCommand}" />
                                    <Button Content="Write Manifest"
                                            Command="{Binding ExportManifestCommand}" />
                                    <Button Content="Open Browser on Quest"
                                            Command="{Binding OpenBrowserCommand}" />
                                </WrapPanel>
                                <Separator Margin="0,10,0,10" />

                                <!-- Last action with outcome color -->
                                <TextBlock Text="Last action" FontWeight="SemiBold" />
                                <Border CornerRadius="4" Padding="8,4" Margin="0,4,0,8"
                                        Background="{Binding LastActionKind, Converter={StaticResource OutcomeKindToSoftBrush}}">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{Binding LastActionKind, Converter={StaticResource OutcomeKindToBrush}}">
                                        <Run Text="{Binding LastActionLabel, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="{Binding LastActionDetail}"
                                           Margin="0,0,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Quest Library">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Session Kit Assets" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="This public repo follows the AstralKarateDojo Quest Session Kit layout directly, with the same staged APK, hotload, and device-profile assets used by the phone companion flow."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <TextBlock Text="App target" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding Apps}"
                                          SelectedItem="{Binding SelectedApp}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                                <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                        Background="{Binding Tags, Converter={StaticResource TagsToSoftBrush}}">
                                                    <TextBlock Text="{Binding Tags, Converter={StaticResource TagsToBadgeText}}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{Binding Tags, Converter={StaticResource TagsToBrush}}" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- Pipeline compatibility label -->
                                <Border CornerRadius="4" Padding="8,4" Margin="0,4,0,6"
                                        Background="{Binding SelectedApp.Tags, Converter={StaticResource TagsToSoftBrush}}">
                                    <TextBlock Text="{Binding SelectedAppPipelineLabel}" TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{Binding SelectedApp.Tags, Converter={StaticResource TagsToBrush}}" />
                                </Border>
                                <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                                        Background="{StaticResource PanelAltBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Capability summary" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedAppCapabilitySummary}"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedAppCommunicationSummary}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="APK path" FontWeight="SemiBold" />
                                <TextBox Text="{Binding SelectedAppApkPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Browse APK"
                                        Command="{Binding BrowseApkCommand}" />
                                <TextBlock Text="Install bundle" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding Bundles}"
                                          SelectedItem="{Binding SelectedBundle}"
                                          DisplayMemberPath="Label" />
                                <TextBlock Text="Runtime preset" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding AvailableHotloadProfiles}"
                                          SelectedItem="{Binding SelectedHotloadProfile}"
                                          DisplayMemberPath="Label" />
                                <TextBlock Text="Device profile" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding DeviceProfiles}"
                                          SelectedItem="{Binding SelectedDeviceProfile}"
                                          DisplayMemberPath="Label" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Quest Actions" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="ADB install, launch, device tuning, and runtime-preset staging stay public here, while the private overlay is limited to the live coupling runtime handoff."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <WrapPanel>
                                    <Button Content="Install Selected App"
                                            Command="{Binding InstallAppCommand}" />
                                    <Button Content="Install Bundle"
                                            Command="{Binding InstallBundleCommand}" />
                                        <Button Content="Publish Runtime Preset"
                                            Command="{Binding ApplyHotloadCommand}" />
                                    <Button Content="Apply Device Profile"
                                            Command="{Binding ApplyDeviceProfileCommand}" />
                                    <Button Content="Launch Selected App"
                                            Command="{Binding LaunchAppCommand}"
                                            Background="{StaticResource AccentSoftBrush}"
                                            FontWeight="Bold" />
                                    <Button Content="Refresh Foreground App"
                                            Command="{Binding RefreshForegroundCommand}" />
                                </WrapPanel>

                                <Separator Margin="0,10,0,10" />

                                <!-- Foreground with colored chip -->
                                <TextBlock Text="Foreground summary" FontWeight="SemiBold" />
                                <Border CornerRadius="4" Padding="8,4" Margin="0,4,0,4"
                                        Background="{Binding ForegroundStatusLevel, Converter={StaticResource OutcomeKindToSoftBrush}}">
                                    <TextBlock Text="{Binding ForegroundSummary}" TextWrapping="Wrap"
                                               Foreground="{Binding ForegroundStatusLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                </Border>

                                <!-- Foreground mismatch warning -->
                                <Border CornerRadius="4" Padding="8,4" Margin="0,0,0,12"
                                        Visibility="{Binding IsForegroundMismatch, Converter={StaticResource BoolToVisibility}}"
                                        Background="{StaticResource StatusWarningSoftBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                                                   Foreground="{StaticResource StatusWarningBrush}" />
                                        <TextBlock Text="{Binding ForegroundMismatchLabel}" TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Foreground="{StaticResource StatusWarningBrush}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Selected target" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedAppSummary}"
                                           Margin="0,4,0,12"
                                           TextWrapping="Wrap" />

                                <TextBlock Text="Performance Levels" FontWeight="SemiBold" />
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="CPU" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding CpuLevelText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="3" Text="GPU" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox Grid.Column="4"
                                             Text="{Binding GpuLevelText, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Button Content="Apply CPU / GPU Levels"
                                        Command="{Binding ApplyPerformanceLevelsCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Runtime Config">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <!-- Header with accent underline -->
                            <TextBlock Text="Astral Runtime Config"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,0,4" />
                            <Border Height="2" Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Left" Width="60"
                                    CornerRadius="1" Margin="0,0,0,8" />
                            <TextBlock Text="This workspace exposes the actual Astral hotload keyspace and serialized runtime-config bridge. Only the live coupling jobs stay private."
                                       Style="{StaticResource SectionCaptionStyle}" />

                            <!-- Profile selector -->
                            <TextBlock Text="PROFILE" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding RuntimeConfig.Profiles}"
                                      SelectedItem="{Binding RuntimeConfig.SelectedProfile}"
                                      DisplayMemberPath="Label" />
                            <Border Background="{StaticResource PanelAltBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="0,0,0,14">
                                <TextBlock Text="{Binding RuntimeConfig.SelectedProfileSummary}"
                                           FontSize="12" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}" />
                            </Border>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,0,0,14" />

                            <!-- Catalog status -->
                            <TextBlock Text="CATALOG STATUS" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,0,4" />
                            <Border Background="{StaticResource StatusInfoSoftBrush}"
                                    BorderBrush="{StaticResource StatusInfoBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="10,6" Margin="0,0,0,6">
                                <TextBlock Text="{Binding RuntimeConfig.CatalogStatus}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </Border>
                            <TextBlock Text="{Binding RuntimeConfig.CatalogSourcePath}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11"
                                       Margin="0,0,0,14"
                                       TextWrapping="Wrap" />

                            <!-- Last export -->
                            <TextBlock Text="LAST EXPORT" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding RuntimeConfig.LastExportPath}"
                                       Margin="0,0,0,14"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,0,0,14" />

                            <!-- Actions -->
                            <WrapPanel>
                                <Button Content="Restore Profile"
                                        Command="{Binding ResetRuntimeConfigCommand}" />
                                <Button Content="Export Config"
                                        Command="{Binding ExportRuntimeConfigCommand}" />
                                <Button Content="Publish over Twin"
                                        Command="{Binding PublishRuntimeConfigCommand}"
                                        Background="{StaticResource AccentSoftBrush}"
                                        FontWeight="SemiBold" />
                            </WrapPanel>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,6,0,12" />

                            <!-- Twin sync legend in a styled card -->
                            <TextBlock Text="TWIN SYNC LEGEND" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,0,6" />
                            <Border Background="{StaticResource PanelAltBrush}"
                                    CornerRadius="6" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Ellipse.Fill><SolidColorBrush Color="#3A9D5C" /></Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="Verified" FontSize="11" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Ellipse.Fill><SolidColorBrush Color="#CCA02E" /></Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="Reported mismatch" FontSize="11" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Ellipse.Fill><SolidColorBrush Color="#B84C4C" /></Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="No live report" FontSize="11" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Ellipse.Fill><SolidColorBrush Color="#CDBEAC" /></Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="Inactive" FontSize="11" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="Runtime Config Workspace"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,0,4" />
                                <Border Height="2" Background="{StaticResource AccentBrush}"
                                        HorizontalAlignment="Left" Width="60"
                                        CornerRadius="1" Margin="0,0,0,8" />
                                <TextBlock Text="Astral twin mode uses three separate channels: on-demand device snapshot over ADB/hzdb, operator publish over quest_hotload_config and quest_twin_commands, and continuous live values over quest_twin_state."
                                           Style="{StaticResource SectionCaptionStyle}" />

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="{StaticResource PanelAltBrush}"
                                            CornerRadius="8"
                                            Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="1. Device Snapshot"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="On demand over ADB and hzdb"
                                                       Margin="0,2,0,8"
                                                       Style="{StaticResource SectionCaptionStyle}" />
                                            <TextBlock Text="{Binding RuntimeConfigDeviceModeSummary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding HeadsetForegroundPackage}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding DeviceSnapshotAgeLabel}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Background="{StaticResource PanelAltBrush}"
                                            CornerRadius="8"
                                            Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="2. Operator Publish"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Operator → headset over quest_hotload_config and quest_twin_commands"
                                                       Margin="0,2,0,8"
                                                       Style="{StaticResource SectionCaptionStyle}" />
                                            <TextBlock Text="{Binding RuntimeConfigPublishChannelSummary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding SelectedAppPipelineLabel}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding RuntimeConfig.SelectedProfileSummary}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                    </Border>

                                        <Border Grid.Column="4"
                                            Background="{StaticResource StatusInfoSoftBrush}"
                                            BorderBrush="{StaticResource StatusInfoBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="3. Live LSL State"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource StatusInfoBrush}" />
                                            <TextBlock Text="Headset → operator over quest_twin_state"
                                                       Margin="0,2,0,8"
                                                       Style="{StaticResource SectionCaptionStyle}" />
                                            <TextBlock Text="{Binding RuntimeConfigLiveSummary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding LiveTwinPublisherLabel}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource StatusInfoBrush}" />
                                            <TextBlock Text="{Binding LiveTwinPublisherDetail}"
                                                       Margin="0,2,0,8"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedBrush}" />
                                            <TextBlock Text="{Binding TwinTrackingCoverageSummary}"
                                                       Margin="0,0,0,8"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedBrush}" />
                                            <TextBlock Text="Live values appear below and in Twin Monitor > Live Twin Monitor."
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding IsForegroundMismatch, Converter={StaticResource BoolToVisibility}}"
                                        Background="{StaticResource StatusWarningSoftBrush}">
                                    <TextBlock Text="{Binding ForegroundMismatchLabel}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{StaticResource StatusWarningBrush}" />
                                </Border>

                                <TextBlock Text="Live Runtime Values"
                                           Margin="0,12,0,4"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="These are the values currently being reported by the live quest_twin_state publisher, not the values staged for publish."
                                           Style="{StaticResource SectionCaptionStyle}"
                                           Margin="0,0,0,6" />
                                <DataGrid ItemsSource="{Binding TwinReportedState}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          MaxHeight="180"
                                          Margin="0,0,0,10"
                                          Visibility="{Binding TwinReportedState.Count, Converter={StaticResource CountToVisibility}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="2*" />
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding RuntimeConfig.Sections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PanelAltBrush}"
                                                    CornerRadius="8"
                                                    Margin="0,0,0,14"
                                                    Padding="0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Accent left stripe -->
                                                    <Border Grid.Column="0"
                                                            Background="{StaticResource AccentBrush}"
                                                            CornerRadius="8,0,0,8" />
                                                    <StackPanel Grid.Column="1" Margin="14,12,14,12">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="15" FontWeight="Bold"
                                                                   Foreground="{StaticResource InkBrush}"
                                                                   Margin="0,0,0,2" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   Style="{StaticResource SectionCaptionStyle}"
                                                                   Margin="0,0,0,10" />
                                                        <ItemsControl ItemsSource="{Binding Rows}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Twin Monitor">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Device Snapshot" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Device-level information is collected only when requested. This keeps ADB and hzdb out of the steady-state loop while the app relies on LSL for live runtime state."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <CheckBox Content="Enable Remote-Only Control"
                                          IsChecked="{Binding RemoteOnlyControlEnabled}" />
                                <Border CornerRadius="4" Padding="8,4" Margin="0,6,0,12"
                                        Background="{Binding IsQuestConnected, Converter={StaticResource BoolToSoftBrush}}">
                                    <TextBlock Text="{Binding RemoteControlModeSummary}"
                                               TextWrapping="Wrap"
                                               Foreground="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}" />
                                </Border>
                                <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,10"
                                        Background="{Binding IsQuestConnected, Converter={StaticResource BoolToSoftBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding HeadsetStatusSummary}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}" />
                                        <TextBlock Text="{Binding HeadsetStatusDetail}"
                                                   Margin="0,2,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding DeviceSnapshotAgeLabel}"
                                           Margin="0,0,0,12"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap" />

                                <TextBlock Text="ADB Snapshot" FontWeight="SemiBold" />
                                <Border CornerRadius="4" Padding="8,6" Margin="0,4,0,10"
                                        Background="{StaticResource PanelAltBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding HeadsetBatteryLabel}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding HeadsetPerformanceLabel}" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding HeadsetForegroundPackage}" Margin="0,4,0,0"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding HeadsetVisibleActivities}" Margin="0,4,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="hzdb Detail" FontWeight="SemiBold" />
                                <Border CornerRadius="4" Padding="8,6" Margin="0,4,0,12"
                                        Background="{StaticResource StatusInfoSoftBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding HzdbStatusSummary}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource StatusInfoBrush}" />
                                        <TextBlock Text="{Binding HzdbStatusDetail}"
                                                   Margin="0,2,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Selected device profile" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedDeviceProfile.Description}"
                                           Margin="0,4,0,12"
                                           TextWrapping="Wrap" />

                                <WrapPanel>
                                    <Button Content="Refresh Device Snapshot"
                                            Command="{Binding RefreshHeadsetStatusCommand}" />
                                    <Button Content="Apply Device Profile"
                                            Command="{Binding ApplyDeviceProfileCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Live Twin Monitor" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="This is the passive live view. Anything the headset runtime publishes on quest_twin_state is shown here without polling ADB. Use Runtime Config to publish, then use this tab to watch what the runtime actually reports back."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,12"
                                        Background="{StaticResource PanelAltBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Selection vs live source" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding RemoteControlSelectionSummary}"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding RemoteControlLiveContextSummary}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="4" Padding="8,4" Margin="0,4,0,12"
                                        Background="{StaticResource StatusInfoSoftBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TwinAppStateSummary}" TextWrapping="Wrap"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource StatusInfoBrush}" />
                                        <TextBlock Text="{Binding TwinAppStateDetail}" Margin="0,2,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{Binding LastTwinStateTimestampLabel}" Margin="0,4,0,0"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Live twin publisher" FontWeight="SemiBold" />
                                <Border CornerRadius="4" Padding="8,4" Margin="0,4,0,12"
                                        Background="{StaticResource StatusInfoSoftBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding LiveTwinPublisherLabel}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource StatusInfoBrush}" />
                                        <TextBlock Text="{Binding LiveTwinPublisherDetail}"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Twin bridge" FontWeight="SemiBold" />
                                <Border CornerRadius="4" Padding="8,4" Margin="0,4,0,12"
                                        Background="{StaticResource PanelAltBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TwinBridgeSummary}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding TwinBridgeDetail}" Margin="0,2,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Runtime publish path" FontWeight="SemiBold" />
                                <TextBlock Text="Publishing controls live in Runtime Config. This monitor tab is only for observing the live twin publisher, reported values, and raw frames."
                                       Margin="0,4,0,12"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedBrush}" />

                                <TextBlock Text="Reported App State" FontWeight="SemiBold" />
                                <DataGrid ItemsSource="{Binding TwinReportedState}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          MaxHeight="280"
                                          Margin="0,4,0,12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="2*" />
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Requested vs Reported Config" FontWeight="SemiBold" />
                                <DataGrid ItemsSource="{Binding SettingsDelta}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          MaxHeight="260"
                                          Margin="0,4,0,12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="2*" />
                                        <DataGridTextColumn Header="Requested" Binding="{Binding Requested}" Width="*" />
                                        <DataGridTextColumn Header="Reported" Binding="{Binding Reported}" Width="*" />
                                        <DataGridCheckBoxColumn Header="Match" Binding="{Binding Matches}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Raw LSL State Frames" FontWeight="SemiBold" />
                                <DataGrid ItemsSource="{Binding TwinLiveEvents}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          MaxHeight="300"
                                          Margin="0,4,0,0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="90" />
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                                        <DataGridTextColumn Header="Payload" Binding="{Binding Payload}" Width="2*" />
                                        <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="LSL Monitor">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Live Monitor" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="The monitor follows the same `quest_monitor` / `quest.telemetry` contract used by the phone companion, including reconnect and idle-state reporting."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <TextBlock Text="{Binding MonitorValueLabel}"
                                           FontSize="36"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}" />
                                <ProgressBar Minimum="0"
                                             Maximum="1"
                                             Height="14"
                                             Margin="0,10,0,10"
                                             Value="{Binding MonitorValue, Mode=OneWay}" />
                                <TextBlock Text="Status" FontWeight="SemiBold" />
                                <Border CornerRadius="4" Padding="8,4" Margin="0,4,0,8"
                                        Background="{StaticResource StatusInfoSoftBrush}">
                                    <TextBlock Text="{Binding MonitorSummary}" TextWrapping="Wrap"
                                               Foreground="{StaticResource StatusInfoBrush}" />
                                </Border>
                                <TextBlock Text="Detail" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding MonitorDetail}" Margin="0,4,0,8" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="Sample rate" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding MonitorRateLabel}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Stream Contract" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Keep the same stream-name / type / channel contract used in the phone monitor."
                                           Style="{StaticResource SectionCaptionStyle}" />
                                <TextBlock Text="Stream name" FontWeight="SemiBold" />
                                <TextBox Text="{Binding MonitorStreamName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Stream type" FontWeight="SemiBold" />
                                <TextBox Text="{Binding MonitorStreamType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Channel index" FontWeight="SemiBold" />
                                <TextBox Text="{Binding MonitorChannelIndexText, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Restart Monitor"
                                        Command="{Binding RestartMonitorCommand}"
                                        Background="{StaticResource AccentSoftBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Diagnostics">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Utility Actions" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="These mirror the operator shortcuts in the Quest Session Kit phone controller."
                                       Style="{StaticResource SectionCaptionStyle}" />
                            <ItemsControl ItemsSource="{Binding UtilityActions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Label}"
                                                ToolTip="{Binding Description}"
                                                Command="{Binding DataContext.RunUtilityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Value}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="Operator Log" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="A concise session log is what the public repo documents; the private compute path stays behind the overlay boundary."
                                           Style="{StaticResource SectionCaptionStyle}" />
                            </StackPanel>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Logs}"
                                     BorderThickness="0"
                                     Background="{StaticResource PanelBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,8,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="6" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0" Width="4" RadiusX="2" RadiusY="2"
                                                           HorizontalAlignment="Left"
                                                           Fill="{Binding Level, Converter={StaticResource LogLevelToBrush}}" />
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock FontFamily="{StaticResource MonoFont}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource MutedBrush}">
                                                        <Run Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                                        <Run Text="  " />
                                                        <Run Text="{Binding Level}"
                                                             Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Message}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                                                               Margin="0,4,0,2" />
                                                <TextBlock Text="{Binding Detail}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource MutedBrush}" />
                                            </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
