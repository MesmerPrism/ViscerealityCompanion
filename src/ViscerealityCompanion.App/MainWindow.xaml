                                            VerticalAlignment="Top">
                                    <Button Content="Refresh Snapshot"
                                            Command="{Binding ActiveStudyShell.RefreshDeviceSnapshotCommand}"
                                            Margin="0,0,0,8" />
                                    <Button Content="{Binding ActiveStudyShell.StudyRuntimeActionLabel}"
                                            Command="{Binding ActiveStudyShell.ToggleStudyRuntimeCommand}"
                                            Style="{StaticResource StateActionButtonStyle}"
                                            Tag="{Binding ActiveStudyShell.StudyRuntimeActionLabel, Converter={StaticResource ActionLabelToIsEnabling}}"
                                            Margin="0" />
                                </StackPanel>
                            </Grid>
                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Connection details" Style="{StaticResource EyebrowStyle}" />
                                </Expander.Header>
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Text="Transport"
                                               Style="{StaticResource EyebrowStyle}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.ConnectionTransportSummary}"
                                               Style="{StaticResource MicroCaptionStyle}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.ConnectionTransportDetail, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="Quest link"
                                               Style="{StaticResource EyebrowStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding ActiveStudyShell.ConnectionSummary, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.HeadsetForegroundLabel, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding ActiveStudyShell.QuestStatusDetail, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="Network"
                                               Style="{StaticResource EyebrowStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding ActiveStudyShell.HeadsetWifiSummary, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.DeviceSnapshotTimestampLabel, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding ActiveStudyShell.HeadsetSnapshotModeSummary, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="Headset state"
                                               Style="{StaticResource EyebrowStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding ActiveStudyShell.HeadsetAwakeDetail, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.HeadsetBatteryLabel, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding ActiveStudyShell.HeadsetSoftwareVersionLabel, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding ActiveStudyShell.HeadsetPerformanceLabel, Converter={StaticResource StatusDetailFormatter}}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="0"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10"
                            Background="{Binding ActiveStudyShell.DeviceProfileLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding ActiveStudyShell.DeviceProfileLevel, Converter={StaticResource OutcomeKindToBrush}}">
                        <StackPanel>
                            <TextBlock Text="Device profile" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="{Binding ActiveStudyShell.DeviceProfileSummary}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{Binding ActiveStudyShell.DeviceProfileLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ActiveStudyShell.HeadsetPerformanceLabel}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                            <Button Content="Apply Study Device Profile"
                                    Command="{Binding ActiveStudyShell.ApplyPinnedDeviceProfileCommand}"
                                    Margin="0,8,0,0" />
                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Details" Style="{StaticResource EyebrowStyle}" />
                                </Expander.Header>
                                <TextBlock Text="{Binding ActiveStudyShell.DeviceProfileDetail}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,6,0,0" />
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Margin="0"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10"
                            Background="{Binding ActiveStudyShell.WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding ActiveStudyShell.WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToBrush}}">
                        <StackPanel>
                            <TextBlock Text="Windows environment" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="{Binding ActiveStudyShell.WindowsEnvironmentCardSummary}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{Binding ActiveStudyShell.WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Review managed tooling, liblsl, current Windows-visible LSL publishers, and the shared guided-installer paths before blaming the headset."
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Open windows environment page"
                                        Command="{Binding ActiveStudyShell.OpenWindowsEnvironmentPageCommand}" />
                                <Button Content="Analyze now"
                                        Command="{Binding ActiveStudyShell.AnalyzeWindowsEnvironmentCommand}" />
                            </WrapPanel>
                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Details" Style="{StaticResource EyebrowStyle}" />
                                </Expander.Header>
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Text="{Binding ActiveStudyShell.WindowsEnvironmentCardDetail}"
                                               Style="{StaticResource MicroCaptionStyle}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.MachineLslStateSummary}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding ActiveStudyShell.MachineLslStateLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.MachineLslStateTimestampLabel}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding ActiveStudyShell.LslRuntimeLibrarySummary}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ActiveStudyShell.OperatorDataRootPath}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0"
                                               FontFamily="{StaticResource MonoFont}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.LocalAgentWorkspacePath}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0"
                                               FontFamily="{StaticResource MonoFont}" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6"
                            Margin="0"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10"
                            Background="{Binding ActiveStudyShell.WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding ActiveStudyShell.WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToBrush}}">
                        <StackPanel>
                            <TextBlock Text="Operator workflow" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="Run Sussex in two GUI stages: Sequential Guide, then Experiment Session."
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{Binding ActiveStudyShell.WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Use the guide for setup, Wi-Fi handoff, kiosk launch, and validation. Use Experiment Session for the actual participant recording run."
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Open full sequential session guide"
                                        Command="{Binding ActiveStudyShell.OpenWorkflowGuideWindowCommand}" />
                                <Button Content="Open experiment session window"
                                        Command="{Binding ActiveStudyShell.OpenExperimentSessionWindowCommand}" />
                            </WrapPanel>
                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Details" Style="{StaticResource EyebrowStyle}" />
                                </Expander.Header>
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Text="{Binding ActiveStudyShell.WorkflowCurrentStepSummary}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding ActiveStudyShell.WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.WorkflowCurrentStepDetail}"
                                               Style="{StaticResource MicroCaptionStyle}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.LastActionLabel}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding ActiveStudyShell.LastActionLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding ActiveStudyShell.LastActionDetail}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding LslRuntimeSummary}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FocusBlueBrush}" />
                                    <TextBlock Text="{Binding LslRuntimeDetail}"
                                               Style="{StaticResource MicroCaptionStyle}"
                                               Margin="0,4,0,0"
                                               FontFamily="{StaticResource MonoFont}" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Width="252"
                            Margin="0,0,8,8"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10"
                            Background="{Binding ActiveStudyShell.LiveRuntimeLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding ActiveStudyShell.LiveRuntimeLevel, Converter={StaticResource OutcomeKindToBrush}}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Live runtime" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="{Binding ActiveStudyShell.LiveRuntimeSummary}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{Binding ActiveStudyShell.LiveRuntimeLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ActiveStudyShell.LastTwinStateTimestampLabel}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Details" Style="{StaticResource EyebrowStyle}" />
                                </Expander.Header>
                                <TextBlock Text="{Binding ActiveStudyShell.LiveRuntimeDetail}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,6,0,0" />
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Width="252"
                            Margin="0,0,8,8"
                            Style="{StaticResource StatusBandPanelStyle}"
                            Padding="10"
                            Background="{Binding ActiveStudyShell.LastActionLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                            BorderBrush="{Binding ActiveStudyShell.LastActionLevel, Converter={StaticResource OutcomeKindToBrush}}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Last action" Style="{StaticResource EyebrowStyle}" />
                            <TextBlock Text="{Binding ActiveStudyShell.LastActionLabel}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{Binding ActiveStudyShell.LastActionLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ActiveStudyShell.LastActionDetail}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Details" Style="{StaticResource EyebrowStyle}" />
                                </Expander.Header>
                                <TextBlock Text="{Binding ActiveStudyShell.LastActionDetail}"
                                           Style="{StaticResource MicroCaptionStyle}"
                                           Margin="0,6,0,0" />
                            </Expander>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="14,10"
                CornerRadius="8"
                Background="{StaticResource StatusWarningSoftBrush}"
                BorderBrush="{StaticResource StatusWarningBrush}"
                BorderThickness="1"
                Visibility="{Binding IsSelectedAppIncompatible, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding IncompatibleBannerLabel}"
                       FontWeight="Bold"
                       Foreground="{StaticResource StatusWarningBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="12"
                Visibility="{Binding ShowStandardOperatorSurface, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource StatusBandPanelStyle}"
                        Background="{Binding IsQuestConnected, Converter={StaticResource BoolToSoftBrush}}"
                        BorderBrush="{Binding IsQuestConnected, Converter={StaticResource BoolToBrush}}">
                    <StackPanel>
                        <TextBlock Text="Quest"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding ConnectionStatusLabel}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding HeadsetModel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding SessionHealthSummary}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource StatusBandPanelStyle}"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{Binding BatteryPercent, Converter={StaticResource BatteryToBrush}}">
                    <StackPanel>
                        <TextBlock Text="Battery / Performance"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding HeadsetBatteryLabel}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{Binding BatteryPercent, Converter={StaticResource BatteryToBrush}}" />
                        <TextBlock Text="{Binding HeadsetSoftwareVersionLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,6,0,0" />
                        <ProgressBar Margin="0,8,0,0"
                                     Height="8"
                                     Maximum="100"
                                     Value="{Binding BatteryPercent, Mode=OneWay}"
                                     Foreground="{Binding BatteryPercent, Converter={StaticResource BatteryToBrush}}" />
                        <TextBlock Text="{Binding HeadsetPerformanceLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource StatusBandPanelStyle}"
                        Background="{Binding TargetStatusLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                        BorderBrush="{Binding TargetStatusLevel, Converter={StaticResource OutcomeKindToBrush}}">
                    <StackPanel>
                        <TextBlock Text="On Device"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding HeadsetTargetStatusLabel}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{Binding TargetStatusLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding HeadsetForegroundPackage}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding HeadsetActivityLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding DeviceSnapshotAgeLabel}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6"
                        Style="{StaticResource StatusBandPanelStyle}"
                        Background="{Binding LiveSignalLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                        BorderBrush="{Binding LiveSignalLevel, Converter={StaticResource OutcomeKindToBrush}}">
                    <StackPanel>
                        <TextBlock Text="Live Signals"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding LiveSignalHeadline}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{Binding LiveSignalLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                   TextWrapping="Wrap" />
