<UserControl x:Class="ViscerealityCompanion.App.StudyShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ViscerealityCompanion.App"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1400">
    <UserControl.Resources>
        <local:OutcomeKindToBrushConverter x:Key="OutcomeKindToBrush" />
        <local:OutcomeKindToSoftBrushConverter x:Key="OutcomeKindToSoftBrush" />
        <local:BatteryToBrushConverter x:Key="BatteryToBrush" />
        <local:LogLevelToBrushConverter x:Key="LogLevelToBrush" />
        <local:StatusDetailFormatterConverter x:Key="StatusDetailFormatter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="CompactCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="StudyPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="StudyInsetPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="CompactStatusExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="DataGridCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DataGridCodeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="VisualProfilesDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border x:Name="CellChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CellChrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="CellChrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VisualProfilesCenteredTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="VisualProfilesCenteredWrappedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource VisualProfilesCenteredTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
        </Style>

        <Style x:Key="VisualProfilesColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="VisualProfilesEditorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="RootScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource AppBackgroundBrush}"
                  BorderThickness="0">
        <Grid Margin="4,8,4,6"
              Background="{StaticResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource StudyPanelStyle}" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="0.8*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding StudyLabel}" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="{Binding StudyPartner}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConnectionSummary}"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding ConnectionCardLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                   TextAlignment="Right" />
                        <TextBlock Text="{Binding LastTwinStateTimestampLabel}"
                                   Style="{StaticResource CompactCaptionStyle}"
                                   TextAlignment="Right"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="StudyPhaseTabs"
                        Grid.Row="2"
                        SelectedIndex="{Binding SelectedPhaseTabIndex}">
                <TabItem Header="Home">
                    <StackPanel Margin="0,8,0,0">

                        <!-- Hero orientation -->
                        <Border Style="{StaticResource StudyPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="Sussex experiment operator shell"
                                           FontSize="22"
                                           FontWeight="Bold" />
                                <TextBlock Text="Prepare, run, and monitor live Sussex VR study sessions from a single operator desktop."
                                           FontSize="14"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding StudyDescription}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StudyPanelStyle}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Local agent workspace" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding LocalAgentWorkspaceSummary}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding LocalAgentWorkspaceDetail}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="Workspace folder"
                                               Style="{StaticResource InfoLabelStyle}"
                                               Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding LocalAgentWorkspacePath}"
                                               FontFamily="{StaticResource MonoFont}"
                                               Style="{StaticResource CompactCaptionStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">
                                    <Button Content="Open Agent Workspace"
                                            Command="{Binding OpenLocalAgentWorkspaceCommand}" />
                                    <Button Content="Copy Local Agent Prompt"
                                            Command="{Binding CopyLocalAgentPromptCommand}"
                                            Margin="0,8,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Navigation cards -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Pre-session card -->
                            <Border Grid.Row="0" Grid.Column="0"
                                    Style="{StaticResource StudyInsetPanelStyle}"
                                    Background="{Binding ConnectionCardLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding ConnectionCardLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Pre-session" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="Connect the headset, install the study APK, apply the device profile, and run bench checks."
                                               Style="{StaticResource CompactCaptionStyle}" />
                                    <TextBlock Text="{Binding ConnectionSummary}"
                                               FontWeight="Bold"
                                               Foreground="{Binding ConnectionCardLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding PinnedBuildSummary}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding DeviceProfileSummary}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- During-session card -->
                            <Border Grid.Row="0" Grid.Column="2"
                                    Style="{StaticResource StudyInsetPanelStyle}"
                                    Background="{Binding LslLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding LslLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="During session" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="Monitor live breathing, coherence, particles, position, and LSL timing here, but use the dedicated Experiment Session pop-out for the actual participant run."
                                               Style="{StaticResource CompactCaptionStyle}" />
                                    <TextBlock Text="{Binding LslSummary}"
                                               FontWeight="Bold"
                                               Foreground="{Binding LslLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding ParticlesSummary}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Sequential guide card -->
                            <Border Grid.Row="0" Grid.Column="4"
                                    Style="{StaticResource StudyInsetPanelStyle}"
                                    Background="{Binding WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Sequential guide" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="Run this directly before the live session: setup, Wi-Fi handoff, runtime launch, LSL checks, optional validation capture, then hand off into Experiment Session."
                                               Style="{StaticResource CompactCaptionStyle}" />
                                    <TextBlock Text="{Binding WorkflowCurrentStepSummary}"
                                               FontWeight="Bold"
                                               Foreground="{Binding WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="Open Sequential Guide"
                                                Command="{Binding OpenWorkflowGuideWindowCommand}" />
                                        <Button Content="Open Experiment Session"
                                                Command="{Binding OpenExperimentSessionWindowCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Visual profiles card -->
                            <Border Grid.Row="2" Grid.Column="0"
                                    Style="{StaticResource StudyInsetPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Visual profiles" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="Edit and apply oscillator visual parameters. Compare profiles, tune individual values, and pin a launch override."
                                               Style="{StaticResource CompactCaptionStyle}" />
                                </StackPanel>
                            </Border>

                            <!-- Breathing profiles card -->
                            <Border Grid.Row="2" Grid.Column="2"
                                    Style="{StaticResource StudyInsetPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Breathing profiles" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="Tune controller-breathing sensitivity, calibration, and vibration parameters for the study's breathing-to-particle pipeline."
                                               Style="{StaticResource CompactCaptionStyle}" />
                                </StackPanel>
                            </Border>

                            <!-- Inspect card -->
                            <Border Grid.Row="2" Grid.Column="4"
                                    Style="{StaticResource StudyInsetPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Inspect" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="View the study runtime details, focused live twin-state values, device profile status, and recent twin events."
                                               Style="{StaticResource CompactCaptionStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Workflow overview (condensed) -->
                        <Border Style="{StaticResource StudyPanelStyle}" Margin="0,12,0,0"
                                Background="{Binding WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                BorderBrush="{Binding WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToBrush}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="0.7*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Operator workflow" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding WorkflowCurrentStepSummary}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{Binding WorkflowCurrentStepLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding WorkflowCurrentStepDetail}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0" />
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Style="{StaticResource StudyInsetPanelStyle}"
                                        Background="{Binding LastActionLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                        BorderBrush="{Binding LastActionLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="Live evidence" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="{Binding LastTwinStateTimestampLabel}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding LastActionLabel}"
                                                   Margin="0,8,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding LastActionLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                   Style="{StaticResource CompactCaptionStyle}" />
                                        <TextBlock Text="{Binding LastActionDetail}"
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding LiveRuntimeSummary}"
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Condensed workflow steps -->
                        <Expander Margin="0,12,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="Workflow step details"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0" />
                            </Expander.Header>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0"
                                        Style="{StaticResource StudyInsetPanelStyle}"
                                        Background="{Binding WorkflowSetupLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                        BorderBrush="{Binding WorkflowSetupLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="1. Setup and greenlight" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="{Binding WorkflowSetupSummary}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding WorkflowSetupLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding WorkflowSetupDetail}"
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="2"
                                        Style="{StaticResource StudyInsetPanelStyle}"
                                        Background="{Binding WorkflowKioskLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                        BorderBrush="{Binding WorkflowKioskLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="2. Boundary and runtime launch" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="{Binding WorkflowKioskSummary}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding WorkflowKioskLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding WorkflowKioskDetail}"
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="0"
                                        Style="{StaticResource StudyInsetPanelStyle}"
                                        Background="{Binding WorkflowBenchLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                        BorderBrush="{Binding WorkflowBenchLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="3. Bench verification" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="{Binding WorkflowBenchSummary}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding WorkflowBenchLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding WorkflowBenchDetail}"
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="2"
                                        Style="{StaticResource StudyInsetPanelStyle}"
                                        Background="{Binding WorkflowHandoffLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                        BorderBrush="{Binding WorkflowHandoffLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="4. Participant handoff" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="{Binding WorkflowHandoffSummary}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding WorkflowHandoffLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding WorkflowHandoffDetail}"
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="4" Grid.Column="0"
                                        Style="{StaticResource StudyInsetPanelStyle}"
                                        Background="{Binding WorkflowParticipantStartLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                        BorderBrush="{Binding WorkflowParticipantStartLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="5. Participant start" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="{Binding WorkflowParticipantStartSummary}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding WorkflowParticipantStartLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding WorkflowParticipantStartDetail}"
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="4" Grid.Column="2"
                                        Style="{StaticResource StudyInsetPanelStyle}"
                                        Background="{Binding WorkflowParticipantEndLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                        BorderBrush="{Binding WorkflowParticipantEndLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="6. Participant end" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="{Binding WorkflowParticipantEndSummary}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding WorkflowParticipantEndLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding WorkflowParticipantEndDetail}"
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Expander>

                        <!-- Quick evidence (collapsed) -->
                        <Expander Margin="0,12,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="Quick evidence and guardrails"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0" />
                            </Expander.Header>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource StudyInsetPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Quick evidence" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="{Binding QuestStatusSummary}" Style="{StaticResource CompactCaptionStyle}" />
                                        <TextBlock Text="{Binding HeadsetBatteryLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding HeadsetSoftwareVersionLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding HeadsetPerformanceLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding HeadsetForegroundLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding LslRuntimeTargetLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding LslConnectedStreamLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding LslConnectionStateLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding QuestScreenshotSummary}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Style="{StaticResource StudyInsetPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Protocol guardrails" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Text="Use the physical power button for off-face sleep and wake during participant handoff."
                                                   FontWeight="SemiBold"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="Keep the proximity override active through launch and bench checks, then restore normal proximity after the live session."
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="Wake the controller before launching Sussex."
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="Disconnect USB before boundary creation and participant positioning."
                                                   Style="{StaticResource CompactCaptionStyle}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Expander>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Pre-session">
                    <StackPanel Margin="0,8,0,0">
                        <Border Style="{StaticResource StudyPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="Session setup" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Work through the four setup stages from left to right: connect, install, configure, then verify."
                                           Style="{StaticResource SectionCaptionStyle}" />

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource StudyInsetPanelStyle}"
                                            Background="{Binding ConnectionCardLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                            BorderBrush="{Binding ConnectionCardLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                        <StackPanel>
                                            <TextBlock Text="1. Connect headset" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding ConnectionSummary}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding ConnectionCardLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ConnectionTransportSummary}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding ConnectionTransportLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding HeadsetWifiSummary}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding WifiNetworkMatchSummary}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding WifiNetworkMatchLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,2,0,0" />
                                            <TextBlock Text="Quest endpoint" Style="{StaticResource InfoLabelStyle}" Margin="0,10,0,6" />
                                            <TextBox Text="{Binding EndpointDraft, UpdateSourceTrigger=PropertyChanged}" />
                                            <WrapPanel Margin="0,8,0,0">
                                                <Button Content="Probe USB" Command="{Binding ProbeUsbCommand}" />
                                                <Button Content="Find Wi-Fi Quest" Command="{Binding DiscoverWifiCommand}" />
                                                <Button Content="Enable Wi-Fi ADB" Command="{Binding EnableWifiCommand}" />
                                                <Button Content="Connect Quest" Command="{Binding ConnectQuestCommand}" />
                                                <Button Content="Refresh Study Status" Command="{Binding RefreshStatusCommand}" />
                                            </WrapPanel>
                                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                                <Expander.Header>
                                                    <TextBlock Text="Connection details" Style="{StaticResource InfoLabelStyle}" Margin="0" />
                                                </Expander.Header>
                                                <StackPanel Margin="0,6,0,0">
                                                    <TextBlock Text="Transport" Style="{StaticResource InfoLabelStyle}" Margin="0" />
                                                    <TextBlock Text="{Binding ConnectionTransportDetail, Converter={StaticResource StatusDetailFormatter}}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,4,0,0" />
                                                    <TextBlock Text="Network" Style="{StaticResource InfoLabelStyle}" Margin="0,8,0,0" />
                                                    <TextBlock Text="{Binding HeadsetWifiSummary, Converter={StaticResource StatusDetailFormatter}}"
                                                               Style="{StaticResource CompactCaptionStyle}" />
                                                    <TextBlock Text="{Binding HostWifiSummary, Converter={StaticResource StatusDetailFormatter}}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,4,0,0" />
                                                    <TextBlock Text="{Binding DeviceSnapshotTimestampLabel, Converter={StaticResource StatusDetailFormatter}}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,4,0,0" />
                                                    <TextBlock Text="Quest state" Style="{StaticResource InfoLabelStyle}" Margin="0,8,0,0" />
                                                    <TextBlock Text="{Binding QuestStatusDetail, Converter={StaticResource StatusDetailFormatter}}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Style="{StaticResource StudyInsetPanelStyle}"
                                            Background="{Binding PinnedBuildCardLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                            BorderBrush="{Binding PinnedBuildCardLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding StudyApkStepTitle}" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding PinnedBuildSummary}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding PinnedBuildLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding InstalledApkSummary}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding InstalledApkLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding DeviceSnapshotTimestampLabel}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,4,0,0" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Content="Choose Study APK"
                                                        Command="{Binding BrowseApkCommand}"
                                                        Visibility="{Binding CanChooseStudyApk, Converter={StaticResource BoolToVisibility}}" />
                                                <Button Content="{Binding StudyApkInstallButtonLabel}" Command="{Binding InstallStudyAppCommand}" />
                                                <Button Content="{Binding StudyRuntimeActionLabel}"
                                                        Command="{Binding ToggleStudyRuntimeCommand}"
                                                        Style="{StaticResource StateActionButtonStyle}"
                                                        Tag="{Binding StudyRuntimeActionLabel, Converter={StaticResource ActionLabelToIsEnabling}}" />
                                            </WrapPanel>
                                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                                <Expander.Header>
                                                    <TextBlock Text="Build details" Style="{StaticResource InfoLabelStyle}" Margin="0" />
                                                </Expander.Header>
                                                <StackPanel Margin="0,6,0,0">
                                                    <TextBlock Text="Pinned study" Style="{StaticResource InfoLabelStyle}" Margin="0,0,0,4" />
                                                    <TextBlock Text="{Binding PinnedBuildDetail}" Style="{StaticResource CompactCaptionStyle}" />
                                                    <TextBlock Text="{Binding StudyApkSourceLabel}" Style="{StaticResource InfoLabelStyle}" Margin="0,8,0,4" />
                                                    <TextBlock Text="{Binding LocalApkSummary}"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding LocalApkLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                               Style="{StaticResource CompactCaptionStyle}" />
                                                    <TextBlock Text="{Binding LocalApkDetail}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Margin="0,4,0,0" />
                                                    <TextBlock Text="Installed on headset" Style="{StaticResource InfoLabelStyle}" Margin="0,8,0,4" />
                                                    <TextBlock Text="{Binding InstalledApkDetail}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               FontFamily="{StaticResource MonoFont}" />
                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="4"
                                            Style="{StaticResource StudyInsetPanelStyle}"
                                            Background="{Binding DeviceProfileCardLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                            BorderBrush="{Binding DeviceProfileCardLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                        <StackPanel>
                                            <TextBlock Text="3. Apply study device profile" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding DeviceProfileSummary}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding DeviceProfileLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding DeviceProfileDetail}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding DeviceSnapshotTimestampLabel}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,4,0,0" />
                                            <Button Content="Apply Study Device Profile"
                                                    Command="{Binding ApplyPinnedDeviceProfileCommand}"
                                                    Margin="0,10,0,0" />
                                            <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                                <Expander.Header>
                                                    <TextBlock Text="Profile details" Style="{StaticResource InfoLabelStyle}" Margin="0" />
                                                </Expander.Header>
                                                <DataGrid ItemsSource="{Binding DeviceProfileRows}"
                                                          AutoGenerateColumns="False"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          IsReadOnly="True"
                                                          HeadersVisibility="Column"
                                                          Margin="0,6,0,0"
                                                          MaxHeight="180">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Property" Binding="{Binding Label}" Width="2.1*" />
                                                        <DataGridTextColumn Header="Live" Binding="{Binding Value}" Width="1.1*" />
                                                        <DataGridTextColumn Header="Expected" Binding="{Binding Expected}" Width="1.1*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Expander>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="6"
                                            Style="{StaticResource StudyInsetPanelStyle}"
                                            Background="{Binding BenchToolsCardLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                            BorderBrush="{Binding BenchToolsCardLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                        <StackPanel>
                                            <TextBlock Text="4. Bench tools" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding BenchToolsSummary}"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding BenchToolsCardLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                       Style="{StaticResource CompactCaptionStyle}" />
                                            <TextBlock Text="Use these only for headset-side bench checks. Windows-only diagnostics now live on the dedicated Windows environment page."
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,4,0,0" />

                                            <Border Margin="0,10,0,0"
                                                    Padding="10"
                                                    Background="{Binding ProximityLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                                    BorderBrush="{Binding ProximityLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="Proximity Sensor" Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Text="{Binding ProximitySummary}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding ProximityLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding ProximityEvidenceLabel}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,6,0,0" />
                                                    <TextBlock Text="{Binding ProximityDetail}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,6,0,0" />
                                                    <Button Content="{Binding ProximityActionLabel}"
                                                            Command="{Binding ToggleProximityCommand}"
                                                            Style="{StaticResource StateActionButtonStyle}"
                                                            Tag="{Binding ProximityActionLabel, Converter={StaticResource ActionLabelToIsEnabling}}"
                                                            IsEnabled="{Binding CanToggleProximity}"
                                                            Margin="0,10,0,0" />
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="0,10,0,0"
                                                    Padding="10"
                                                    Background="{Binding QuestScreenshotLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                                    BorderBrush="{Binding QuestScreenshotLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="Quest Screenshot" Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Text="{Binding QuestScreenshotSummary}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding QuestScreenshotLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding QuestScreenshotDetail}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,6,0,0"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding QuestScreenshotPath}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,6,0,0"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               TextWrapping="Wrap" />
                                                    <Image Source="{Binding QuestScreenshotPreview}"
                                                           Stretch="Uniform"
                                                           MaxHeight="180"
                                                           Margin="0,8,0,0" />
                                                    <WrapPanel Margin="0,10,0,0">
                                                        <Button Content="Capture Quest Screenshot"
                                                                Command="{Binding CaptureQuestScreenshotCommand}"
                                                                IsEnabled="{Binding CanCaptureQuestScreenshot}" />
                                                        <Button Content="Open Last Screenshot"
                                                                Command="{Binding OpenLastQuestScreenshotCommand}"
                                                                IsEnabled="{Binding CanOpenLastQuestScreenshot}" />
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="0,10,0,0"
                                                    Padding="10"
                                                    Background="{Binding WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                                    BorderBrush="{Binding WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="Windows-side diagnostics moved" Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Text="{Binding WindowsEnvironmentCardSummary}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding WindowsEnvironmentCardDetail}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,6,0,0"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="TEST sender, Machine LSL State, and Analyze Windows Environment now live on their own page so the Pre-session setup column stays readable."
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,4,0,0" />
                                                    <Button x:Name="OpenWindowsEnvironmentPageButton"
                                                            Content="Open Windows Environment Page"
                                                            Command="{Binding OpenWindowsEnvironmentPageCommand}"
                                                            Margin="0,10,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </TabItem>

                <TabItem Header="During session">
                    <StackPanel Margin="0,8,0,0">

                        <!-- Row 1: Particles + Performance side by side -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding ParticlesLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding ParticlesLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Particle visibility" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding ParticlesSummary}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{Binding ParticlesLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ParticlesDetail}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <Button Content="{Binding ParticlesToggleActionLabel}"
                                            Command="{Binding ToggleParticlesCommand}"
                                            IsEnabled="{Binding CanToggleParticles}"
                                            Style="{StaticResource StateActionButtonStyle}"
                                            Tag="{Binding ParticlesToggleActionLabel, Converter={StaticResource ActionLabelToIsEnabling}}"
                                            Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding PerformanceLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding PerformanceLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Performance" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding PerformanceSummary}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{Binding PerformanceLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <ProgressBar Margin="0,10,0,0"
                                                 Height="8"
                                                 Maximum="100"
                                                 Value="{Binding PerformancePercent, Mode=OneWay}"
                                                 Foreground="{Binding PerformanceLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding PerformanceValueLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding PerformanceDetail}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Row 2: Breathing + Coherence side by side -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding ControllerLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding ControllerLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding BreathingStatusTitle}" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding ControllerSummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding ControllerLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ControllerCalibrationLabel}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0" />
                                    <ProgressBar Margin="0,10,0,0"
                                                 Height="8"
                                                 Maximum="100"
                                                 Value="{Binding BreathingDriverValuePercent, Mode=OneWay}"
                                                 Foreground="{Binding ControllerLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding BreathingDriverValueText}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0" />

                                    <Border Margin="0,10,0,0"
                                            Padding="10"
                                            Background="{StaticResource SurfaceTintBrush}"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Calibration setup" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding ControllerBreathingProfiles.CalibrationModeSummary}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ControllerBreathingProfiles.CalibrationAcceptanceSummary}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ControllerBreathingProfiles.CalibrationModeDetail}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,8,0,0">
                                                <Button Content="Use Dynamic Motion Axis"
                                                        Command="{Binding ControllerBreathingProfiles.UseDynamicAxisCalibrationCommand}"
                                                        Margin="0,0,8,0" />
                                                <Button Content="Use Fixed Controller Orientation"
                                                        Command="{Binding ControllerBreathingProfiles.UseFixedOrientationCalibrationCommand}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,10,0,0"
                                            Padding="10"
                                            Visibility="{Binding ControllerCalibrationQualityVisible, Converter={StaticResource BoolToVisibility}}"
                                            Background="{Binding ControllerCalibrationQualityLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                            BorderBrush="{Binding ControllerCalibrationQualityLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Calibration quality" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding ControllerCalibrationQualityBadge}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding ControllerCalibrationQualityLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ControllerCalibrationQualitySummary}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding ControllerCalibrationQualityExpectation}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                        <Expander.Header>
                                            <TextBlock Text="Breathing driver" Style="{StaticResource InfoLabelStyle}" Margin="0" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,6,0,0">
                                            <TextBlock Text="{Binding AutomaticBreathingSummary}" Style="{StaticResource CompactCaptionStyle}" />
                                            <TextBlock Text="{Binding AutomaticBreathingDetail}" Style="{StaticResource CompactCaptionStyle}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,8,0,0">
                                                <Button Content="{Binding AutomaticBreathingModeActionLabel}"
                                                        Command="{Binding ToggleAutomaticBreathingModeCommand}"
                                                        Style="{StaticResource StateActionButtonStyle}"
                                                        Tag="{Binding AutomaticBreathingModeActionLabel, Converter={StaticResource ActionLabelToIsEnabling}}"
                                                        IsEnabled="{Binding CanToggleAutomaticBreathingMode}" />
                                                <Button Content="{Binding AutomaticBreathingRunActionLabel}"
                                                        Command="{Binding ToggleAutomaticBreathingRunCommand}"
                                                        Style="{StaticResource StateActionButtonStyle}"
                                                        Tag="{Binding AutomaticBreathingRunActionLabel, Converter={StaticResource ActionLabelToIsEnabling}}"
                                                        IsEnabled="{Binding CanToggleAutomaticBreathingRun}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding CoherenceLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding CoherenceLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Coherence" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding CoherenceSummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding CoherenceLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <ProgressBar Margin="0,10,0,0"
                                                 Height="8"
                                                 Maximum="100"
                                                 Value="{Binding CoherencePercent, Mode=OneWay}"
                                                 Foreground="{Binding CoherenceLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding CoherenceValueLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding CoherenceRouteSummary}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding CoherenceDetail}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Row 3: Recenter+Distance + Screenshot side by side -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding RecenterLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding RecenterLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Distance from center" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding RecenterSummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding RecenterLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <ProgressBar Margin="0,10,0,0"
                                                 Height="8"
                                                 Maximum="100"
                                                 Value="{Binding RecenterDistancePercent, Mode=OneWay}"
                                                 Foreground="{Binding RecenterLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding RecenterDistanceLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding RecenterDetail}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                    <Button Content="Send Recenter"
                                            Command="{Binding RecenterCommand}"
                                            IsEnabled="{Binding CanSendRecenterCommand}"
                                            Margin="0,12,0,0"
                                            FontWeight="Bold" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding QuestScreenshotLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding QuestScreenshotLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Quest screenshot" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding QuestScreenshotSummary}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{Binding QuestScreenshotLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding QuestScreenshotDetail}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                    <Image Source="{Binding QuestScreenshotPreview}"
                                           Stretch="Uniform"
                                           MaxHeight="120"
                                           Margin="0,8,0,0" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Content="Capture Quest Screenshot"
                                                Command="{Binding CaptureQuestScreenshotCommand}"
                                                IsEnabled="{Binding CanCaptureQuestScreenshot}" />
                                        <Button Content="Open Last Screenshot"
                                                Command="{Binding OpenLastQuestScreenshotCommand}"
                                                IsEnabled="{Binding CanOpenLastQuestScreenshot}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Row 4: LSL Clock Alignment + LSL Input side by side -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding ClockAlignmentLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding ClockAlignmentLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="LSL clock alignment" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding ClockAlignmentSummary}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{Binding ClockAlignmentLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <ProgressBar Margin="0,10,0,0"
                                                 Height="8"
                                                 Maximum="100"
                                                 Value="{Binding ClockAlignmentProgressPercent, Mode=OneWay}"
                                                 Foreground="{Binding ClockAlignmentLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding ClockAlignmentProgressLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding ClockAlignmentDetail}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                        <Expander.Header>
                                            <TextBlock Text="Alignment stats" Style="{StaticResource InfoLabelStyle}" Margin="0" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,6,0,0">
                                            <TextBlock Text="{Binding ClockAlignmentProbeStatsLabel}" Style="{StaticResource CompactCaptionStyle}" />
                                            <TextBlock Text="{Binding ClockAlignmentOffsetStatsLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding ClockAlignmentRoundTripStatsLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding LslLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding LslLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="LSL input" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding LslSummary}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{Binding LslLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <ProgressBar Margin="0,10,0,0"
                                                 Height="8"
                                                 Maximum="100"
                                                 Value="{Binding LslValuePercent, Mode=OneWay}"
                                                 Foreground="{Binding LslLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                    <TextBlock Text="{Binding LslValueLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding LslConnectionStateLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,6,0,0" />
                                    <Expander Style="{StaticResource CompactStatusExpanderStyle}">
                                        <Expander.Header>
                                            <TextBlock Text="LSL details" Style="{StaticResource InfoLabelStyle}" Margin="0" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,6,0,0">
                                            <TextBlock Text="{Binding LslConnectedStreamLabel}" Style="{StaticResource CompactCaptionStyle}" FontFamily="{StaticResource MonoFont}" />
                                            <TextBlock Text="{Binding LslRuntimeTargetLabel}" Style="{StaticResource CompactCaptionStyle}" FontFamily="{StaticResource MonoFont}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding LslEchoStateLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding LslBenchStateLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding LslStatusLineLabel}" Style="{StaticResource CompactCaptionStyle}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding LslDetail}" Style="{StaticResource CompactCaptionStyle}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Operator log (collapsible) -->
                        <Expander Margin="0,12,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="Operator log"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0" />
                            </Expander.Header>
                                <ListBox ItemsSource="{Binding Logs}" MaxHeight="220" Margin="0,10,0,0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Message}"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}" />
                                                <TextBlock Text="{Binding Detail}" Style="{StaticResource CompactCaptionStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                        </Expander>
                    </StackPanel>
                </TabItem>

                <TabItem x:Name="VisualProfilesTab"
                         Header="Visual Profiles"
                         DataContext="{Binding VisualProfiles}">
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding LibraryLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding LibraryLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Saved profile library" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding LibrarySummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding LibraryLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LibraryDetail}"
                                               Style="{StaticResource SectionCaptionStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding TemplatePathLabel, StringFormat=Template: {0}}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding LibraryRootLabel, StringFormat=Folder: {0}}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,2,0,0" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button Content="New From Baseline" Command="{Binding NewFromBaselineCommand}" />
                                        <Button x:Name="VisualSaveAsNewProfileButton"
                                                Content="Save Draft As New Profile"
                                                Click="OnVisualSaveAsNewProfileClick"
                                                AutomationProperties.AutomationId="VisualSaveAsNewProfileButton" />
                                        <Button x:Name="VisualSaveSelectedProfileButton"
                                                Content="Save Changes To Selected Profile"
                                                Click="OnVisualSaveSelectedProfileClick"
                                                AutomationProperties.AutomationId="VisualSaveSelectedProfileButton" />
                                        <Button Content="Import" Command="{Binding ImportProfileCommand}" />
                                        <Button Content="Export" Command="{Binding ExportSelectedCommand}" />
                                        <Button Content="Open Folder" Command="{Binding OpenFolderCommand}" />
                                        <Button Content="Delete" Command="{Binding DeleteSelectedCommand}" />
                                    </WrapPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Selecting a saved profile loads it into the working draft below. Typing in the table does not change the library until you use one of the save buttons."
                                               Style="{StaticResource CompactCaptionStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StudyPanelStyle}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Saved profiles" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="The bundled Sussex baseline is always listed first. Read-only bundled release profiles follow it, and writable local profiles stay in the local library."
                                               Style="{StaticResource SectionCaptionStyle}" />
                                    <ListBox ItemsSource="{Binding Profiles}"
                                             SelectedItem="{Binding SelectedProfile}"
                                             Margin="0,10,0,0"
                                             MinHeight="260"
                                             Height="320">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SecondaryLabel}"
                                                               Style="{StaticResource CompactCaptionStyle}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StudyPanelStyle}"
                                    Margin="0,12,0,0"
                                    Background="{Binding ApplyLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding ApplyLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Apply and confirmation" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding ApplySummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding ApplyLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ApplyDetail}"
                                               Style="{StaticResource SectionCaptionStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding LastCompiledCsvPath, StringFormat=Last CSV: {0}}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource StudyPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Runtime working draft" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="The selected saved profile is copied into this runtime draft. Applying changes touches only the live Sussex session; saving decides whether the library or launch profile changes."
                                               Style="{StaticResource SectionCaptionStyle}" />

                                    <Border Style="{StaticResource StudyInsetPanelStyle}"
                                            Margin="0,4,0,0"
                                            Background="{StaticResource SurfaceTintBrush}"
                                            BorderBrush="{StaticResource LineBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Next launch override" Style="{StaticResource InfoLabelStyle}" />
                                                <TextBlock Text="{Binding StartupProfileSummary}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding StartupProfileDetail}"
                                                           Style="{StaticResource CompactCaptionStyle}"
                                                           Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource StudyInsetPanelStyle}"
                                            Margin="0,8,0,0"
                                            Background="{Binding DraftLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                            BorderBrush="{Binding DraftLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                        <StackPanel>
                                            <TextBlock Text="Runtime draft source" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding DraftSourceSummary}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding DraftSourceDetail}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource StudyInsetPanelStyle}"
                                            Margin="0,8,0,0"
                                            Background="{Binding DraftLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                            BorderBrush="{Binding DraftLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                        <StackPanel>
                                            <TextBlock Text="Draft state" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding DraftSummary}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"
                                                       Foreground="{Binding DraftLevel, Converter={StaticResource OutcomeKindToBrush}}" />
                                            <TextBlock Text="{Binding DraftDetail}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Draft name"
                                                   Style="{StaticResource InfoLabelStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="0"
                                                 Grid.Column="1"
                                                 Grid.ColumnSpan="5"
                                                 Text="{Binding SelectedProfileName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Draft notes"
                                                   Style="{StaticResource InfoLabelStyle}"
                                                   VerticalAlignment="Top" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 AcceptsReturn="True"
                                                 MinHeight="64"
                                                 Text="{Binding SelectedProfileNotes, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource StudyPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="Visual parameter table" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="The table edits the runtime working draft and compares it against the saved launch profile shown above. Reset returns a row to the bundled Sussex baseline."
                                                   Style="{StaticResource SectionCaptionStyle}" />
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="1*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Padding="12"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Background="#11000000">
                                                <StackPanel>
                                                    <TextBlock Text="Current session"
                                                               Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Margin="0,4,0,8"
                                                               Text="Publish the runtime working draft to the active Sussex session now. This changes only the live session and leaves the saved launch profile untouched."
                                                               Style="{StaticResource SectionCaptionStyle}" />
                                                    <Button x:Name="VisualApplyCurrentSessionButton"
                                                            Content="Apply Runtime Draft To Current Session"
                                                            Click="OnVisualApplyCurrentSessionClick"
                                                            MinWidth="220"
                                                            FontWeight="Bold"
                                                            AutomationProperties.AutomationId="VisualApplyCurrentSessionButton" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    Padding="12"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Background="#11000000">
                                                <StackPanel>
                                                    <TextBlock Text="Next Sussex launch"
                                                               Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Margin="0,4,0,8"
                                                               Text="Pin the selected saved profile as the persisted Sussex launch profile. Save the runtime draft first if you want the current draft values to become the next-launch profile."
                                                               Style="{StaticResource SectionCaptionStyle}" />
                                                    <WrapPanel>
                                                        <Button x:Name="VisualSaveStartupSnapshotButton"
                                                                Content="{Binding StartupProfileActionLabel}"
                                                                Click="OnVisualSaveStartupSnapshotClick"
                                                                MinWidth="260"
                                                                MinHeight="40"
                                                                FontWeight="Bold"
                                                                AutomationProperties.AutomationId="VisualSaveStartupSnapshotButton" />
                                                        <Button x:Name="VisualUseBundledStartupButton"
                                                                Content="Use Bundled Baseline"
                                                                Command="{Binding UseBundledStartupCommand}"
                                                                MinWidth="220"
                                                                MinHeight="40"
                                                                AutomationProperties.AutomationId="VisualUseBundledStartupButton" />
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>

                                    <DataGrid x:Name="VisualProfilesTable"
                                               ItemsSource="{Binding ComparisonRows}"
                                               AutoGenerateColumns="False"
                                               CanUserAddRows="False"
                                               CanUserDeleteRows="False"
                                               CanUserResizeRows="False"
                                               IsReadOnly="False"
                                               HeadersVisibility="Column"
                                               Grid.Row="2"
                                               MinHeight="620"
                                               GridLinesVisibility="Horizontal"
                                               PreviewMouseWheel="OnVisualProfilesTablePreviewMouseWheel"
                                               ScrollViewer.VerticalScrollBarVisibility="Auto"
                                               ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                               ColumnHeaderStyle="{StaticResource VisualProfilesColumnHeaderStyle}"
                                               CellStyle="{StaticResource VisualProfilesDataGridCellStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Group" Width="0.85*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Group}"
                                                                   AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=visual-group-{0}}"
                                                                   Style="{StaticResource VisualProfilesCenteredWrappedTextStyle}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Parameter" Width="1.8*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}"
                                                                   ToolTip="{Binding ToolTipText}"
                                                                   AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=visual-label-{0}}"
                                                                   Style="{StaticResource VisualProfilesCenteredWrappedTextStyle}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Range"
                                                                Binding="{Binding Range}"
                                                                Width="0.95*"
                                                                IsReadOnly="True"
                                                                ElementStyle="{StaticResource VisualProfilesCenteredTextStyle}" />
                                            <DataGridTemplateColumn Header="Current" Width="0.88*" IsReadOnly="False">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <TextBox Text="{Binding CurrentValueText, UpdateSourceTrigger=LostFocus}"
                                                                     ToolTip="{Binding ToolTipText}"
                                                                     AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=visual-current-{0}}"
                                                                     AutomationProperties.Name="{Binding Label, StringFormat=Current value for {0}}">
                                                                <TextBox.Style>
                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource VisualProfilesEditorTextBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsBooleanEditor}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>
                                                            <CheckBox IsChecked="{Binding CurrentBoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Click="OnProfileBooleanToggleClick"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      ToolTip="{Binding ToolTipText}"
                                                                      AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=visual-current-{0}}"
                                                                      AutomationProperties.Name="{Binding Label, StringFormat=Current value for {0}}">
                                                                <CheckBox.Style>
                                                                    <Style TargetType="CheckBox">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsBooleanEditor}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </CheckBox.Style>
                                                            </CheckBox>
                                                        </Grid>
                                                    </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Saved Launch Override" Width="0.9*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Startup}"
                                                                   AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=visual-startup-{0}}"
                                                                   AutomationProperties.Name="{Binding Startup}"
                                                                   Style="{StaticResource VisualProfilesCenteredTextStyle}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Δ Launch Override"
                                                                Binding="{Binding DeltaFromStartup}"
                                                                Width="0.9*"
                                                                IsReadOnly="True"
                                                                ElementStyle="{StaticResource VisualProfilesCenteredTextStyle}" />
                                            <DataGridTemplateColumn Header="Status" Width="0.85*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Confirmation}"
                                                                   Foreground="{Binding ConfirmationLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                                   Style="{StaticResource VisualProfilesCenteredTextStyle}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Reset" Width="0.7*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Reset"
                                                                HorizontalAlignment="Center"
                                                                Command="{Binding DataContext.ResetFieldCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding Field}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ControllerBreathingTab"
                         Header="Breathing Profiles"
                         DataContext="{Binding ControllerBreathingProfiles}">
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding LibraryLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding LibraryLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Controller-breathing profile library" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding LibrarySummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding LibraryLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LibraryDetail}"
                                               Style="{StaticResource SectionCaptionStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding TemplatePathLabel, StringFormat=Template: {0}}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding LibraryRootLabel, StringFormat=Folder: {0}}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,2,0,0" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button Content="New From Baseline" Command="{Binding NewFromBaselineCommand}" />
                                        <Button Content="Duplicate" Command="{Binding DuplicateSelectedCommand}" />
                                        <Button Content="Rename" Command="{Binding RenameSelectedCommand}" />
                                        <Button Content="Import" Command="{Binding ImportProfileCommand}" />
                                        <Button Content="Export" Command="{Binding ExportSelectedCommand}" />
                                        <Button Content="Open Folder" Command="{Binding OpenFolderCommand}" />
                                        <Button Content="Delete" Command="{Binding DeleteSelectedCommand}" />
                                    </WrapPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Session apply and next-launch save actions live with the table below so they always commit the edited cell first."
                                               Style="{StaticResource CompactCaptionStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StudyPanelStyle}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Saved profiles" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Each profile is stored as a self-describing json file in the local library."
                                               Style="{StaticResource SectionCaptionStyle}" />
                                    <ListBox ItemsSource="{Binding Profiles}"
                                             SelectedItem="{Binding SelectedProfile}"
                                             Margin="0,10,0,0"
                                             MinHeight="260"
                                             Height="320">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SecondaryLabel}"
                                                               Style="{StaticResource CompactCaptionStyle}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StudyPanelStyle}"
                                    Margin="0,12,0,0"
                                    Background="{Binding ApplyLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding ApplyLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Apply and confirmation" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding ApplySummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding ApplyLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ApplyDetail}"
                                               Style="{StaticResource SectionCaptionStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding LastCompiledCsvPath, StringFormat=Last CSV: {0}}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource StudyPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Selected profile" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Edit values in the table below. Hover a parameter name for the metadata and tuning guidance bundled in the profile schema. Applying a profile resets controller-breathing calibration in the Sussex runtime."
                                               Style="{StaticResource SectionCaptionStyle}" />

                                    <Border Style="{StaticResource StudyInsetPanelStyle}"
                                            Margin="0,8,0,0"
                                            Background="{StaticResource SurfaceTintBrush}"
                                            BorderBrush="{StaticResource LineBrush}">
                                        <StackPanel>
                                            <TextBlock Text="Calibration setup" Style="{StaticResource InfoLabelStyle}" />
                                            <TextBlock Text="{Binding CalibrationModeSummary}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CalibrationAcceptanceSummary}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CalibrationModeDetail}"
                                                       Style="{StaticResource CompactCaptionStyle}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Content="Use Dynamic Motion Axis"
                                                        Command="{Binding UseDynamicAxisCalibrationCommand}"
                                                        Margin="0,0,8,0" />
                                                <Button Content="Use Fixed Controller Orientation"
                                                        Command="{Binding UseFixedOrientationCalibrationCommand}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource StudyInsetPanelStyle}"
                                            Margin="0,4,0,0"
                                            Background="{StaticResource SurfaceTintBrush}"
                                            BorderBrush="{StaticResource LineBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Next launch override" Style="{StaticResource InfoLabelStyle}" />
                                                <TextBlock Text="{Binding StartupProfileSummary}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding StartupProfileDetail}"
                                                           Style="{StaticResource CompactCaptionStyle}"
                                                           Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Profile name"
                                                   Style="{StaticResource InfoLabelStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="0"
                                                 Grid.Column="1"
                                                 Grid.ColumnSpan="5"
                                                 Text="{Binding SelectedProfileName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Notes"
                                                   Style="{StaticResource InfoLabelStyle}"
                                                   VerticalAlignment="Top" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 AcceptsReturn="True"
                                                 MinHeight="64"
                                                 Text="{Binding SelectedProfileNotes, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource StudyPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="Controller-breathing parameter table" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="The table compares the current editor values against the saved launch override shown above. The first Calibration Setup rows let you choose dynamic motion axis versus fixed controller orientation and tune how much movement counts as an accepted calibration. Sussex may briefly start on the bundled baseline before that override lands. Reset returns a row to the bundled Sussex baseline. Recalibrate on the headset after every apply."
                                                   Style="{StaticResource SectionCaptionStyle}" />
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="1*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Padding="12"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Background="#11000000">
                                                <StackPanel>
                                                    <TextBlock Text="Current session"
                                                               Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Margin="0,4,0,8"
                                                               Text="Upload the edited breathing-tuning values to the headset now. This does not change the next Sussex launch."
                                                               Style="{StaticResource SectionCaptionStyle}" />
                                                    <Button x:Name="ControllerApplyCurrentSessionButton"
                                                            Content="Apply To Current Session"
                                                            Click="OnControllerApplyCurrentSessionClick"
                                                            MinWidth="220"
                                                            FontWeight="Bold"
                                                            AutomationProperties.AutomationId="ControllerApplyCurrentSessionButton" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    Padding="12"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Background="#11000000">
                                                <StackPanel>
                                                    <TextBlock Text="Next Sussex launch"
                                                               Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Margin="0,4,0,8"
                                                               Text="Save the current breathing-tuning values as the pinned launch override used the next time Sussex launches from this shell."
                                                               Style="{StaticResource SectionCaptionStyle}" />
                                                    <WrapPanel>
                                                        <Button x:Name="ControllerSaveStartupSnapshotButton"
                                                                Content="{Binding StartupProfileActionLabel}"
                                                                Click="OnControllerSaveStartupSnapshotClick"
                                                                MinWidth="260"
                                                                MinHeight="40"
                                                                FontWeight="Bold"
                                                                AutomationProperties.AutomationId="ControllerSaveStartupSnapshotButton" />
                                                        <Button x:Name="ControllerUseBundledStartupButton"
                                                                Content="Use Bundled Baseline"
                                                                Command="{Binding UseBundledStartupCommand}"
                                                                MinWidth="220"
                                                                MinHeight="40"
                                                                AutomationProperties.AutomationId="ControllerUseBundledStartupButton" />
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>

                                    <DataGrid x:Name="ControllerProfilesTable"
                                               ItemsSource="{Binding ComparisonRows}"
                                               AutoGenerateColumns="False"
                                               CanUserAddRows="False"
                                               CanUserDeleteRows="False"
                                               CanUserResizeRows="False"
                                               IsReadOnly="False"
                                               HeadersVisibility="Column"
                                               Grid.Row="2"
                                               MinHeight="620"
                                               GridLinesVisibility="Horizontal"
                                               PreviewMouseWheel="OnVisualProfilesTablePreviewMouseWheel"
                                               ScrollViewer.VerticalScrollBarVisibility="Auto"
                                               ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                               ColumnHeaderStyle="{StaticResource VisualProfilesColumnHeaderStyle}"
                                               CellStyle="{StaticResource VisualProfilesDataGridCellStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Group" Width="0.85*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Group}"
                                                                   AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=controller-group-{0}}"
                                                                   Style="{StaticResource VisualProfilesCenteredWrappedTextStyle}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Parameter" Width="1.8*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}"
                                                                   ToolTip="{Binding ToolTipText}"
                                                                   AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=controller-label-{0}}"
                                                                   Style="{StaticResource VisualProfilesCenteredWrappedTextStyle}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Range"
                                                                Binding="{Binding Range}"
                                                                Width="0.95*"
                                                                IsReadOnly="True"
                                                                ElementStyle="{StaticResource VisualProfilesCenteredTextStyle}" />
                                            <DataGridTemplateColumn Header="Current" Width="0.88*" IsReadOnly="False">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <TextBox Text="{Binding CurrentValueText, UpdateSourceTrigger=LostFocus}"
                                                                     ToolTip="{Binding ToolTipText}"
                                                                     AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=controller-current-{0}}"
                                                                     AutomationProperties.Name="{Binding Label, StringFormat=Current value for {0}}">
                                                                <TextBox.Style>
                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource VisualProfilesEditorTextBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsBooleanEditor}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>
                                                            <CheckBox IsChecked="{Binding CurrentBoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Click="OnProfileBooleanToggleClick"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      ToolTip="{Binding ToolTipText}"
                                                                      AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=controller-current-{0}}"
                                                                      AutomationProperties.Name="{Binding Label, StringFormat=Current value for {0}}">
                                                                <CheckBox.Style>
                                                                    <Style TargetType="CheckBox">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsBooleanEditor}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </CheckBox.Style>
                                                            </CheckBox>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Saved Launch Override" Width="0.9*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Startup}"
                                                                   AutomationProperties.AutomationId="{Binding Field.Id, StringFormat=controller-startup-{0}}"
                                                                   AutomationProperties.Name="{Binding Startup}"
                                                                   Style="{StaticResource VisualProfilesCenteredTextStyle}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Δ Launch Override"
                                                                Binding="{Binding DeltaFromStartup}"
                                                                Width="0.9*"
                                                                IsReadOnly="True"
                                                                ElementStyle="{StaticResource VisualProfilesCenteredTextStyle}" />
                                            <DataGridTemplateColumn Header="Status" Width="0.85*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Confirmation}"
                                                                   Foreground="{Binding ConfirmationLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                                                   Style="{StaticResource VisualProfilesCenteredTextStyle}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Reset" Width="0.7*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Reset"
                                                                HorizontalAlignment="Center"
                                                                Command="{Binding DataContext.ResetFieldCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding Field}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Inspect">
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.96*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1.04*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource StudyPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Study runtime" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Inspect the exact APK target and install state the Sussex shell is enforcing."
                                               Style="{StaticResource SectionCaptionStyle}" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Package id" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PinnedPackageId}" Style="{StaticResource CompactCaptionStyle}" FontFamily="{StaticResource MonoFont}" />
                                        <TextBlock Grid.Row="2" Text="Version" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PinnedBuildVersion}" Style="{StaticResource CompactCaptionStyle}" />
                                        <TextBlock Grid.Row="4" Text="Launch component" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PinnedLaunchComponent}" Style="{StaticResource CompactCaptionStyle}" FontFamily="{StaticResource MonoFont}" />
                                        <TextBlock Grid.Row="6" Text="Study SHA256" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PinnedBuildHash}" Style="{StaticResource CompactCaptionStyle}" FontFamily="{StaticResource MonoFont}" />
                                        <TextBlock Grid.Row="8" Text="{Binding StudyApkSourceLabel}" Style="{StaticResource InfoLabelStyle}" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding StagedApkPath}" Style="{StaticResource CompactCaptionStyle}" />
                                    </Grid>
                                    <TextBlock Text="{Binding PinnedAppNotes}" Style="{StaticResource CompactCaptionStyle}" Margin="0,12,0,0" />
                                    <TextBlock Text="{Binding InstalledApkDetail}" Style="{StaticResource CompactCaptionStyle}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StudyPanelStyle}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Study device profile" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding DeviceProfileSummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding DeviceProfileLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding DeviceProfileDetail}"
                                               Style="{StaticResource SectionCaptionStyle}"
                                               Margin="0,8,0,0" />
                                    <DataGrid ItemsSource="{Binding DeviceProfileRows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              Margin="0,10,0,0"
                                              MaxHeight="320">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Property" Binding="{Binding Label}" Width="2.2*" />
                                            <DataGridTextColumn Header="Live" Binding="{Binding Value}" Width="1.3*" />
                                            <DataGridTextColumn Header="Expected" Binding="{Binding Expected}" Width="1.1*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource StudyPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Focused live values"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding LastTwinStateTimestampLabel}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               VerticalAlignment="Center" />

                                    <ComboBox Grid.Row="2"
                                              Grid.ColumnSpan="2"
                                              ItemsSource="{Binding LiveSections}"
                                              SelectedItem="{Binding SelectedLiveSection}" />

                                    <DataGrid Grid.Row="4"
                                              Grid.ColumnSpan="2"
                                              ItemsSource="{Binding FocusRows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              IsReadOnly="True"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              HeadersVisibility="Column"
                                              Height="320"
                                              MinHeight="320"
                                              MaxHeight="320"
                                              ScrollViewer.CanContentScroll="True"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Signal"
                                                                Binding="{Binding Label}"
                                                                Width="210"
                                                                ElementStyle="{StaticResource DataGridCellTextStyle}" />
                                            <DataGridTextColumn Header="Live"
                                                                Binding="{Binding Value}"
                                                                Width="240"
                                                                ElementStyle="{StaticResource DataGridCellTextStyle}" />
                                            <DataGridTextColumn Header="Expected"
                                                                Binding="{Binding Expected}"
                                                                Width="210"
                                                                ElementStyle="{StaticResource DataGridCellTextStyle}" />
                                            <DataGridTextColumn Header="Key"
                                                                Binding="{Binding Key}"
                                                                Width="*"
                                                                ElementStyle="{StaticResource DataGridCodeTextStyle}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource StudyPanelStyle}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Recent twin events" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding RecentTwinEvents.Count, StringFormat=Showing {0} recent events from the live quest_twin_state stream.}"
                                               Style="{StaticResource SectionCaptionStyle}" />
                                    <ListBox ItemsSource="{Binding RecentTwinEvents}"
                                             Margin="0,10,0,0"
                                             MaxHeight="260"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="12"
                                                        Background="{StaticResource PanelAltBrush}"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                                   Style="{StaticResource CompactCaptionStyle}" />
                                                        <TextBlock Text="{Binding Category}"
                                                                   FontWeight="Bold"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding Detail}"
                                                                   Style="{StaticResource CompactCaptionStyle}"
                                                                   Margin="0,6,0,0" />
                                                        <TextBlock Text="{Binding Payload}"
                                                                   Style="{StaticResource CompactCaptionStyle}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Windows environment">
                    <StackPanel Margin="0,8,0,0">
                        <Border Style="{StaticResource StudyPanelStyle}"
                                Background="{Binding WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                BorderBrush="{Binding WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToBrush}}">
                            <StackPanel>
                                <TextBlock Text="Windows environment" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding WindowsEnvironmentCardSummary}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{Binding WindowsEnvironmentCardLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding WindowsEnvironmentCardDetail}"
                                           Style="{StaticResource SectionCaptionStyle}"
                                           Margin="0,6,0,0" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button x:Name="AnalyzeWindowsEnvironmentOverviewButton"
                                            Content="Analyze Windows Environment"
                                            Command="{Binding AnalyzeWindowsEnvironmentCommand}" />
                                    <Button x:Name="CleanInstallFootprintButton"
                                            Content="Clean Install Footprint"
                                            Command="{Binding CleanInstallFootprintCommand}" />
                                    <Button Content="Refresh Machine LSL State"
                                            Command="{Binding RefreshMachineLslStateCommand}" />
                                    <Button x:Name="GenerateDiagnosticsReportButton"
                                            Content="Generate Diagnostics Report"
                                            Command="{Binding GenerateDiagnosticsReportCommand}"
                                            Style="{StaticResource StateActionButtonStyle}" />
                                    <Button Content="{Binding TestLslSenderActionLabel}"
                                            Command="{Binding ToggleTestLslSenderCommand}"
                                            Style="{StaticResource StateActionButtonStyle}"
                                            Tag="{Binding TestLslSenderActionLabel, Converter={StaticResource ActionLabelToIsEnabling}}"
                                            IsEnabled="{Binding CanToggleTestLslSender}" />
                                    <Button Content="Open Agent Workspace"
                                            Command="{Binding OpenLocalAgentWorkspaceCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StudyPanelStyle}"
                                Margin="0,12,0,0"
                                Background="{Binding DiagnosticsReportLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                BorderBrush="{Binding DiagnosticsReportLevel, Converter={StaticResource OutcomeKindToBrush}}">
                            <StackPanel>
                                <TextBlock Text="Sussex diagnostics report" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding DiagnosticsReportSummary}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{Binding DiagnosticsReportLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding DiagnosticsReportTimestampLabel}"
                                           Style="{StaticResource CompactCaptionStyle}"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="{Binding DiagnosticsReportDetail}"
                                           Style="{StaticResource CompactCaptionStyle}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Report folder"
                                           Style="{StaticResource InfoLabelStyle}"
                                           Margin="0,10,0,6" />
                                <TextBlock Text="{Binding DiagnosticsReportFolderPath}"
                                           Style="{StaticResource CompactCaptionStyle}"
                                           FontFamily="{StaticResource MonoFont}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Report PDF"
                                           Style="{StaticResource InfoLabelStyle}"
                                           Margin="0,10,0,6" />
                                <TextBlock Text="{Binding DiagnosticsReportPdfPath}"
                                           Style="{StaticResource CompactCaptionStyle}"
                                           FontFamily="{StaticResource MonoFont}"
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="Generate Diagnostics Report"
                                            Command="{Binding GenerateDiagnosticsReportCommand}"
                                            Style="{StaticResource StateActionButtonStyle}" />
                                    <Button x:Name="OpenDiagnosticsReportFolderButton"
                                            Content="Open Report Folder"
                                            Command="{Binding OpenDiagnosticsReportFolderCommand}"
                                            IsEnabled="{Binding CanOpenDiagnosticsReportFolder}"
                                            Style="{StaticResource StateActionButtonStyle}" />
                                    <Button x:Name="OpenDiagnosticsReportPdfButton"
                                            Content="Open Report PDF"
                                            Command="{Binding OpenDiagnosticsReportPdfCommand}"
                                            IsEnabled="{Binding CanOpenDiagnosticsReportPdf}"
                                            Style="{StaticResource StateActionButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource StudyPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Host-visible paths" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="These are the Windows-side paths the packaged app, guided installer, and exported local-agent workspace should share on this machine."
                                               Style="{StaticResource SectionCaptionStyle}" />

                                    <TextBlock Text="Operator data root"
                                               Style="{StaticResource InfoLabelStyle}"
                                               Margin="0,10,0,6" />
                                    <TextBlock Text="{Binding OperatorDataRootPath}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               FontFamily="{StaticResource MonoFont}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="Managed tooling root"
                                               Style="{StaticResource InfoLabelStyle}"
                                               Margin="0,10,0,6" />
                                    <TextBlock Text="{Binding ManagedToolingRootPath}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               FontFamily="{StaticResource MonoFont}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="Local agent workspace"
                                               Style="{StaticResource InfoLabelStyle}"
                                               Margin="0,10,0,6" />
                                    <TextBlock Text="{Binding LocalAgentWorkspacePath}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               FontFamily="{StaticResource MonoFont}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LocalAgentWorkspaceDetail}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="Current liblsl runtime"
                                               Style="{StaticResource InfoLabelStyle}"
                                               Margin="0,10,0,6" />
                                    <TextBlock Text="{Binding LslRuntimeLibrarySummary}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LslRuntimeLibraryDetail}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0"
                                               FontFamily="{StaticResource MonoFont}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource StudyPanelStyle}"
                                    Background="{Binding TestLslSenderLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                    BorderBrush="{Binding TestLslSenderLevel, Converter={StaticResource OutcomeKindToBrush}}">
                                <StackPanel>
                                    <TextBlock Text="Windows TEST LSL Sender" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding TestLslSenderSummary}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{Binding TestLslSenderLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TestLslSenderValueLabel}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding TestLslSenderDetail}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LslRuntimeLibrarySummary}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding LslRuntimeLibraryDetail}"
                                               Style="{StaticResource CompactCaptionStyle}"
                                               Margin="0,6,0,0"
                                               FontFamily="{StaticResource MonoFont}"
                                               TextWrapping="Wrap" />
                                    <Button Content="{Binding TestLslSenderActionLabel}"
                                            Command="{Binding ToggleTestLslSenderCommand}"
                                            Style="{StaticResource StateActionButtonStyle}"
                                            Tag="{Binding TestLslSenderActionLabel, Converter={StaticResource ActionLabelToIsEnabling}}"
                                            IsEnabled="{Binding CanToggleTestLslSender}"
                                            Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource StudyPanelStyle}"
                                Margin="0,12,0,0"
                                Background="{Binding MachineLslStateLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                BorderBrush="{Binding MachineLslStateLevel, Converter={StaticResource OutcomeKindToBrush}}">
                            <StackPanel>
                                <TextBlock Text="Machine LSL State" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding MachineLslStateSummary}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{Binding MachineLslStateLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding MachineLslStateTimestampLabel}"
                                           Style="{StaticResource CompactCaptionStyle}"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="{Binding MachineLslStateDetail}"
                                           Style="{StaticResource CompactCaptionStyle}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                                <Button x:Name="RefreshMachineLslStateButton"
                                        Content="Refresh Machine LSL State"
                                        Command="{Binding RefreshMachineLslStateCommand}"
                                        Style="{StaticResource StateActionButtonStyle}"
                                        Margin="0,10,0,0" />
                                <ItemsControl ItemsSource="{Binding MachineLslStateChecks}"
                                              Margin="0,10,0,0"
                                              Visibility="{Binding MachineLslStateHasRun, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="8"
                                                    Background="{Binding Level, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                                    BorderBrush="{Binding Level, Converter={StaticResource OutcomeKindToBrush}}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Detail}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,4,0,0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StudyPanelStyle}"
                                Margin="0,12,0,0"
                                Background="{Binding WindowsEnvironmentAnalysisLevel, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                BorderBrush="{Binding WindowsEnvironmentAnalysisLevel, Converter={StaticResource OutcomeKindToBrush}}">
                            <StackPanel>
                                <TextBlock Text="Windows Environment Analysis" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding WindowsEnvironmentAnalysisSummary}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{Binding WindowsEnvironmentAnalysisLevel, Converter={StaticResource OutcomeKindToBrush}}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding WindowsEnvironmentAnalysisTimestampLabel}"
                                           Style="{StaticResource CompactCaptionStyle}"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="{Binding WindowsEnvironmentAnalysisDetail}"
                                           Style="{StaticResource CompactCaptionStyle}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                                <Button x:Name="AnalyzeWindowsEnvironmentButton"
                                        Content="Analyze Windows Environment"
                                        Command="{Binding AnalyzeWindowsEnvironmentCommand}"
                                        Style="{StaticResource StateActionButtonStyle}"
                                        Margin="0,10,0,0" />
                                <ItemsControl ItemsSource="{Binding WindowsEnvironmentChecks}"
                                              Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="8"
                                                    Background="{Binding Level, Converter={StaticResource OutcomeKindToSoftBrush}}"
                                                    BorderBrush="{Binding Level, Converter={StaticResource OutcomeKindToBrush}}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource InfoLabelStyle}" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Detail}"
                                                               Style="{StaticResource CompactCaptionStyle}"
                                                               Margin="0,4,0,0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </ScrollViewer>
</UserControl>
