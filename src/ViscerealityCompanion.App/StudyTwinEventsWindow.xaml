<Window x:Class="ViscerealityCompanion.App.StudyTwinEventsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ViscerealityCompanion.App"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Twin Event Log"
        Icon="Assets/viscereality-companion.ico"
        Width="980"
        Height="720"
        MinWidth="780"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <local:LogLevelToBrushConverter x:Key="LogLevelToBrush" />

        <Style x:Key="GridCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridCodeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource GridCellTextStyle}">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Twin Event Log"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Debug surface for inspecting individual `quest_twin_state` events without adding noise to the main Sussex study page."
                               Style="{StaticResource SectionCaptionStyle}"
                               Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding LastTwinStateTimestampLabel}"
                               FontWeight="Bold"
                               TextAlignment="Right"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding RecentTwinEvents.Count, StringFormat={}{0} buffered event(s)}"
                               Style="{StaticResource SectionCaptionStyle}"
                               Margin="0,6,0,0"
                               TextAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource PanelBorderStyle}"
                Padding="0">
            <DataGrid ItemsSource="{Binding RecentTwinEvents}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      IsReadOnly="True"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      HeadersVisibility="Column"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time"
                                        Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}"
                                        Width="120"
                                        ElementStyle="{StaticResource GridCodeTextStyle}" />
                    <DataGridTextColumn Header="Event"
                                        Binding="{Binding Detail}"
                                        Width="280"
                                        ElementStyle="{StaticResource GridCellTextStyle}" />
                    <DataGridTextColumn Header="Payload"
                                        Binding="{Binding Payload}"
                                        Width="*"
                                        ElementStyle="{StaticResource GridCodeTextStyle}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
