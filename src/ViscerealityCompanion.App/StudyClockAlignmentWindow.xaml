<Window x:Class="ViscerealityCompanion.App.StudyClockAlignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sussex Clock Alignment"
        Width="760"
        Height="430"
        MinWidth="700"
        MinHeight="380"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource InkBrush}">
    <Window.Resources>
        <Style x:Key="ClockPanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        </Style>

        <Style x:Key="ClockTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ClockBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ClockMicroStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="20"
          Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ClockPanelStyle}">
            <StackPanel>
                <TextBlock Text="Clock Alignment"
                           Style="{StaticResource ClockTitleStyle}" />
                <TextBlock Text="A dedicated 10 second LSL round-trip handshake is running before the main Sussex experiment continues. This estimates the Quest-minus-Windows clock offset and the end-to-end loop latency."
                           Style="{StaticResource ClockBodyStyle}"
                           Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource ClockPanelStyle}">
            <StackPanel>
                <TextBlock Text="{Binding ClockAlignmentSummary}"
                           FontSize="21"
                           FontWeight="Bold"
                           Foreground="{StaticResource InkBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ClockAlignmentDetail}"
                           Style="{StaticResource ClockBodyStyle}"
                           Margin="0,8,0,0" />
                <TextBlock Text="{Binding ClockAlignmentProgressLabel}"
                           Style="{StaticResource ClockMicroStyle}"
                           Margin="0,14,0,0" />
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Height="20"
                             Margin="0,8,0,0"
                             Value="{Binding ClockAlignmentProgressPercent, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ClockPanelStyle}"
                    Background="{StaticResource SurfaceTintBrush}">
                <StackPanel>
                    <TextBlock Text="Probe Coverage"
                               Style="{StaticResource ClockMicroStyle}" />
                    <TextBlock Text="{Binding ClockAlignmentProbeStatsLabel}"
                               Style="{StaticResource ClockBodyStyle}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource ClockPanelStyle}"
                    Background="{StaticResource SurfaceTintBrush}">
                <StackPanel>
                    <TextBlock Text="Clock Offset"
                               Style="{StaticResource ClockMicroStyle}" />
                    <TextBlock Text="{Binding ClockAlignmentOffsetStatsLabel}"
                               Style="{StaticResource ClockBodyStyle}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource ClockPanelStyle}"
                    Background="{StaticResource SurfaceTintBrush}">
                <StackPanel>
                    <TextBlock Text="Round-Trip"
                               Style="{StaticResource ClockMicroStyle}" />
                    <TextBlock Text="{Binding ClockAlignmentRoundTripStatsLabel}"
                               Style="{StaticResource ClockBodyStyle}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="6"
                   Text="The window closes automatically after a clean alignment run. If the handshake is incomplete, leave it open and inspect the result."
                   Style="{StaticResource ClockBodyStyle}" />
    </Grid>
</Window>
