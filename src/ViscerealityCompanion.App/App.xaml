<Application x:Class="ViscerealityCompanion.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="UiFont">Bahnschrift</FontFamily>
        <FontFamily x:Key="MonoFont">Consolas</FontFamily>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F2ECE2" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFDF9" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#ECE1D3" />
        <SolidColorBrush x:Key="LineBrush" Color="#CDBEAC" />
        <SolidColorBrush x:Key="InkBrush" Color="#221B17" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6F655B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#9E2E18" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#F2D5CF" />

        <!-- Status indicator colors -->
        <SolidColorBrush x:Key="StatusSuccessBrush" Color="#3A9D5C" />
        <SolidColorBrush x:Key="StatusSuccessSoftBrush" Color="#D4EDDA" />
        <SolidColorBrush x:Key="StatusWarningBrush" Color="#CCA02E" />
        <SolidColorBrush x:Key="StatusWarningSoftBrush" Color="#FFF3CD" />
        <SolidColorBrush x:Key="StatusFailureBrush" Color="#B84C4C" />
        <SolidColorBrush x:Key="StatusFailureSoftBrush" Color="#F8D7DA" />
        <SolidColorBrush x:Key="StatusInfoBrush" Color="#2D6A9F" />
        <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#D1ECF1" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        </Style>
    </Application.Resources>
</Application>
