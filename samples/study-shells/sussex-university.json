{
  "id": "sussex-university",
  "label": "Sussex University",
  "partner": "University of Sussex",
  "description": "Simplified operator window for the Sussex controller-breathing study. The shell pins a single LslTwin build, one Quest device profile, and the live monitoring fields the experimenter needs during a session.",
  "app": {
    "label": "Sussex LslTwin Build",
    "packageId": "com.Viscereality.LslTwin",
    "apkPath": "",
    "launchComponent": "com.Viscereality.LslTwin/com.unity3d.player.UnityPlayerGameActivity",
    "sha256": "E22396E38394DD7EC186E7CEDCEDCC21BAD47D16A8572C7311B8AADDB104AC50",
    "versionName": "0.1.0",
    "notes": "Select the supplied Sussex APK file once. The operator shell will keep checking the local file hash and the installed headset hash against this pinned build."
  },
  "deviceProfile": {
    "id": "sussex-study-profile",
    "label": "Sussex Study Device Profile",
    "description": "Dedicated Quest device settings for the Sussex controller-breathing study.",
    "properties": {
      "debug.oculus.cpuLevel": "5",
      "debug.oculus.gpuLevel": "5",
      "debug.oculus.foveation.dynamic": "false",
      "debug.oculus.foveation.level": "1"
    }
  },
  "monitoring": {
    "expectedBreathingLabel": "Controller Volume",
