{
  "private": true,
  "name": "viscereality-companion-site",
  "description": "Static docs build for ViscerealityCompanion",
  "scripts": {
    "pages:build:html": "node ./tools/site/build-pages.mjs",
    "pages:index": "pagefind --site site",
    "pages:build": "npm run pages:build:html && npm run pages:index",
    "pages:serve": "browser-sync start --server site --files \"site/**/*\" --startPath \"index.html\""
  },
  "devDependencies": {
    "browser-sync": "^3.0.3",
    "marked": "^15.0.7",
    "pagefind": "^1.3.0",
    "yaml": "^2.8.1"
  }
}
